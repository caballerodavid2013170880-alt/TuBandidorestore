@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Tipo de Reparación";
}

@model MantenimientoDetalleViewModel.TipoReparacionViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.TipoReparacion);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.IdTipoReparacion == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <a href="~/TipoReparacion/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText Reparación</span>
                </a>
                <!--end::Title-->

            </div>
            <!--end::Page title-->

        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">

            <!--begin::Card body-->
            <div class="card-body py-4">
                <form class="form w-100" novalidate="novalidate" id="kt_reparacion_in_form" data-kt-redirect-url="/" asp-controller="TipoReparacion" asp-action="AgregarTipoReparacion" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdTipoReparacion" type="hidden" />
                    <div class="fv-row mb-8">
                        <div class="col-sm-12">
                            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                <div asp-validation-summary="All"></div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Descripcion" class="col-form-label text-gray-600 required">Descripción</label>
                                <input asp-for="Descripcion" class="form-control bg-transparent" placeholder="Descripción" />
                                <span asp-validation-for="Descripcion" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdGrupo" class="col-form-label text-gray-600 required">Selecciona un Grupo</label>
                                <select asp-for="IdGrupo" asp-items="new SelectList(Model.Grupos, nameof(MantenimientoDetalleViewModel.GrupoReparacionViewModel.IdGrupo), nameof(MantenimientoDetalleViewModel.GrupoReparacionViewModel.GrupoDescripcionId), Model.IdGrupo)" class="form-control">
                                    <option value="">Selecciona un Grupo</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="IdGrupo"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Valor" class="col-form-label text-gray-600 required">Valor</label>
                                <input asp-for="Valor" class="form-control bg-transparent" placeholder="Valor" maxlength="10" />
                                <span asp-validation-for="Valor" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <button type="submit" id="kt_reparacion_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/tipoReparacion/add.js"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}