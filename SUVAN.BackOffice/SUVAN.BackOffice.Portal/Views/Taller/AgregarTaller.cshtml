@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Taller";
}

@model TallerViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Taller);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.IdTaller == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <a href="~/Taller/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText Taller</span>
                </a>
                <!--end::Title-->

            </div>
            <!--end::Page title-->

        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">

            <!--begin::Card body-->
            <div class="card-body py-4">
                <form class="form w-100" novalidate="novalidate" id="kt_taller_in_form" data-kt-redirect-url="/" asp-controller="Taller" asp-action="AgregarTaller" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="ZonaJson" type="hidden" id="ZonaJson" />
                    <input asp-for="IdTaller" type="hidden" />
                    <div class="fv-row mb-8">
                        <div class="col-sm-12">
                            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                <div asp-validation-summary="All"></div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="NombreTaller" class="col-form-label text-gray-600 required">Nombre del Taller</label>
                                <input asp-for="NombreTaller" class="form-control bg-transparent" placeholder="Nombre del Taller" />
                                <span asp-validation-for="NombreTaller" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Domicilio" class="col-form-label text-gray-600 required">Domicilio</label>
                                <input asp-for="Domicilio" class="form-control bg-transparent" placeholder="Domicilio" />
                                <span asp-validation-for="Domicilio" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="fv-row mb-3">
                                <label asp-for="Contacto" class="col-form-label text-gray-600 required">Contacto</label>
                                <input asp-for="Contacto" class="form-control bg-transparent" placeholder="Contacto" />
                                <span asp-validation-for="Contacto" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="fv-row mb-3">
                                <label asp-for="Telefono" class="col-form-label text-gray-600 required">Teléfono</label>
                                <input asp-for="Telefono" class="form-control bg-transparent" placeholder="Teléfono" maxlength="10"/>
                                <span asp-validation-for="Telefono" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="fv-row mb-3">
                                <label asp-for="Email" class="col-form-label text-gray-600 required">Correo</label>
                                <input asp-for="Email" class="form-control bg-transparent" placeholder="Correo" />
                                <span asp-validation-for="Email" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="ZonaIdzona" class="col-form-label text-gray-600 required">Elige la Zona</label>
                                <select asp-for="ZonaIdzona" asp-items="new SelectList(Model.ZonaView, nameof(TallerViewModel.ZonasViewModel.ZonaId), nameof(TallerViewModel.ZonasViewModel.IdNombre), Model.ZonaIdzona)" class="form-control">
                                    <option value="">Selecciona una Zona</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="ZonaIdzona"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdDeposito" class="col-form-label text-gray-600 required">Elige el Taller</label>
                                <select asp-for="IdDeposito" asp-items="new SelectList(Model.DepositoView, nameof(TallerViewModel.DepositosViewModel.DepositoId), nameof(TallerViewModel.DepositosViewModel.DepositoNombreId), Model.IdDeposito)" class="form-control">
                                    <option value="">Selecciona un depósito</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="IdDeposito"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <button type="submit" id="kt_taller_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/taller/add.js"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}