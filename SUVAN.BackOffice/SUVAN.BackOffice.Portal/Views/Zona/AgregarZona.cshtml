@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Zona";
}

@model ZonaViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Zona);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.ZonaId == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <a href="~/Zona/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText Zona</span>
                </a>
                <!--end::Title-->

            </div>
            <!--end::Page title-->

        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">

            <!--begin::Card body-->
            <div class="card-body py-4">
                <form class="form w-100" novalidate="novalidate" id="kt_zona_in_form" data-kt-redirect-url="/" asp-controller="Zona" asp-action="AgregarZona" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="ZonaId" type="hidden" />
                    <div class="fv-row mb-8">
                        <div class="col-sm-12">
                            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                <div asp-validation-summary="All"></div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="ZonaNombre" class="col-form-label text-gray-600 required">Nombre de la Zona</label>
                                <input asp-for="ZonaNombre" class="form-control bg-transparent" placeholder="Nombre de la Zona" />
                                <span asp-validation-for="ZonaNombre" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Rfc" class="col-form-label text-gray-600 required">RFC</label>
                                <input asp-for="Rfc" class="form-control bg-transparent" placeholder="RFC" />
                                <span asp-validation-for="Rfc" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Domicilio" class="col-form-label text-gray-600 required">Domicilio</label>
                                <input asp-for="Domicilio" class="form-control bg-transparent" placeholder="Domicilio" />
                                <span asp-validation-for="Domicilio" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="fv-row mb-3">
                                <label asp-for="Telefono1" class="col-form-label text-gray-600 required">Teléfono 1</label>
                                <input asp-for="Telefono1" class="form-control bg-transparent" placeholder="Telefono 1" maxlength="10" />
                                <span asp-validation-for="Telefono1" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="fv-row mb-3">
                                <label asp-for="Telefono2" class="col-form-label text-gray-600 required">Teléfono 2</label>
                                <input asp-for="Telefono2" class="form-control bg-transparent" placeholder="Telefono 2" maxlength="10" />
                                <span asp-validation-for="Telefono2" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="fv-row mb-3">
                                <label asp-for="Responsable" class="col-form-label text-gray-600 required">Nombre del Responsable</label>
                                <input asp-for="Responsable" class="form-control bg-transparent" placeholder="Nombre del Responsable" />
                                <span asp-validation-for="Responsable" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="fv-row mb-3">
                                <label asp-for="FechaApertura" class="col-form-label text-gray-600 required">Fecha de Apertura</label>
                                <input asp-for="FechaApertura" class="form-control bg-transparent" placeholder="" value="@Model.FechaApertura.ToString("dd/MM/yyyy")" />
                                <span asp-validation-for="FechaApertura" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-2 d-flex align-items-end">
                            <div class="form-check mb-3">
                                <input asp-for="ActivoBool" class="form-check-input" />
                                <label asp-for="ActivoBool" class="form-check-label">Activo</label>
                            </div>
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" id="kt_zona_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/zona/add.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}
