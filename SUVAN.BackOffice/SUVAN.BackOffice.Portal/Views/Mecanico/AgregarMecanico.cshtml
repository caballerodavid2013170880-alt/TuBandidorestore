@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Mecanico";
}

@model MecanicoViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Mecanico);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.IdMecanico == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <a href="~/Mecanico/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText Mecanico</span>
                </a>
                <!--end::Title-->

            </div>
            <!--end::Page title-->

        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">

            <!--begin::Card body-->
            <div class="card-body py-4">
                <form class="form w-100" novalidate="novalidate" id="kt_mecanico_in_form" data-kt-redirect-url="/" asp-controller="Mecanico" asp-action="AgregarMecanico" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdMecanico" type="hidden" />
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Nombre" class="col-form-label text-gray-600 required">Nombre</label>
                                <input asp-for="Nombre" class="form-control bg-transparent" placeholder="Nombre" />
                                <span asp-validation-for="Nombre" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Apellido" class="col-form-label text-gray-600 required">Apellidos</label>
                                <input asp-for="Apellido" class="form-control bg-transparent" placeholder="Apellidos" />
                                <span asp-validation-for="Apellido" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="FechaIngreso" class="col-form-label text-gray-600 required">Fecha de Ingreso</label>
                                <input asp-for="FechaIngreso" class="form-control bg-transparent" placeholder="" />
                                <span asp-validation-for="FechaIngreso" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Numero" class="col-form-label text-gray-600 required" maxlength="10">Número Telefónico</label>
                                <input asp-for="Numero" class="form-control bg-transparent" placeholder="Número Telefónico" />
                                <span asp-validation-for="Numero" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdDeposito" class="col-form-label text-gray-600 required">Elige el Depósito</label>
                                <select asp-for="IdDeposito" asp-items="new SelectList(Model.DepositoView, nameof(DepositosDisponiblesViewModel.DepositoId), nameof(DepositosDisponiblesViewModel.DepsoitoIdNombre), Model.IdDeposito)" class="form-control">
                                    <option value="">Selecciona una Deposito</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="IdDeposito"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-check form-check-inline">
                                <label asp-for="Activo" class="form-check-label">Activo</label>
                                <input asp-for="Activo" class="form-check-input" />
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <button type="submit" id="kt_mecanico_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/mecanico/add.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}