@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;

@inject IUsuarioHelper UsuarioHelper

@{
    ViewData["Title"] = "Modelo";
}

@model List<SUVAN.BackOffice.Database.Entities.Modelo>

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Modelo);

    if (permisosPagina == null)

    {

        return;

    }
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Modelo</h1>
            </div>
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                @if (permisosPagina!.Agregar)

                {
                    <a href="~/Modelo/AgregarModelo" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Agregar Modelo</a>
                }
            </div>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">
        <div class="card">
            <div class="card-header border-0 pt-6">
                <div class="card-title">
                    <div class="d-flex align-items-center position-relative my-1">
                        <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                        <input type="text" data-kt-modelo-table-filter="search" class="form-control form-control-solid w-450px ps-13" placeholder="Buscar" />
                    </div>
                </div>
            </div>
            <div class="card-body py-4">
                <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_modelo">
                    <thead>
                        <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                            <th class="min-w-125px">Id_marca</th>
                            <th class="min-w-125px">Id_modelo</th>
                            <th class="min-w-100px">Año Desde</th>
                            <th class="min-w-100px">Año Hasta</th>
                            <th class="min-w-125px">Id_tipo_v</th>
                            <th class="min-w-200px">Descripción</th>
                            <th class="min-w-100px">Km Garantía</th>
                            <th class="min-w-100px">Mes Garantía</th>
                            <th class="min-w-100px">Tipo Eje</th>
                            <th class="text-end min-w-100px">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 fw-semibold">
                        @foreach (var modelo in Model)

                        {
                            <tr>
                                <td>@modelo.IdMarca</td>
                                <td>@modelo.IdModelo</td>
                                <td>@modelo.ADesde</td>
                                <td>@modelo.AHasta</td>
                                <td>@modelo.IdTipoV</td>
                                <td>@modelo.Descrip</td>
                                <td>@modelo.KmGaran</td>
                                <td>@modelo.MesGara</td>
                                <td>@modelo.TipoEje</td>
                                <td class="text-end">
                                    @if (permisosPagina!.Editar)

                                    {
                                        <a href="~/Modelo/AgregarModelo/@modelo.IdModelo" class="btn btn-icon btn-active-light-primary w-30px h-30px">
                                            <i class="ki-outline ki-pencil fs-3"></i>
                                        </a>
                                    }
                                    @if (permisosPagina!.Eliminar)

                                    {
                                        <a class="btn btn-icon btn-active-light-primary w-30px h-30px" data-kt-modelo-delete-item="@modelo.IdModelo" data-kt-modelo-table-filter="delete_row">
                                            <i class="ki-outline ki-trash fs-3"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/logistica/Modelo/table.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
    <script src="~/assets/js/custom/utilities/modals/users-search.js" asp-append-version="true"></script>
}