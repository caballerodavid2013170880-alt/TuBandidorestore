@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
    ViewData["Title"] = "Modelo";
}

@model VehiculoDetalleViewModel.ModeloViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Modelo);



    if (permisosPagina == null)

    {

        return;

    }



    var isAgregarText = Model.IdModelo == 0 ? "Agregar" : "Editar";
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <a href="~/Modelo/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0">
                    <i class="ki-duotone ki-left fs-1 pe-5"></i>
                    <span>@isAgregarText Modelo</span>
                </a>
            </div>
        </div>
    </div>
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">
        <div class="card">
            <div class="card-body py-4">
                <form class="form w-100" novalidate="novalidate" id="kt_modelo_in_form" data-kt-redirect-url="/" asp-controller="Modelo" asp-action="AgregarModelo" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdModelo" type="hidden" />

                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdMarca" class="col-form-label text-gray-600 required">Selecciona una Marca</label>
                                <select asp-for="IdMarca" asp-items="new SelectList(Model.MarcasView, nameof(VehiculoDetalleViewModel.MarcaViewModel.IdMarca), nameof(VehiculoDetalleViewModel.MarcaViewModel.DescripcionMarcaId), Model.IdMarca)" class="form-control">
                                    <option value="">Selecciona una Marca</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="IdMarca"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Descripcion" class="col-form-label text-gray-600 required">Descripción</label>
                                <input asp-for="Descripcion" class="form-control bg-transparent" placeholder="Descripción" />
                                <span asp-validation-for="Descripcion" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="AnioDesde" class="col-form-label text-gray-600 required">Año Desde</label>
                                <input asp-for="AnioDesde" type="text" inputmode="numeric" class="form-control bg-transparent" placeholder="Año Desde" maxlength="4" />
                                <span asp-validation-for="AnioDesde" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="AnioHasta" class="col-form-label text-gray-600 required">Año Hasta</label>
                                <input asp-for="AnioHasta" type="text" inputmode="numeric" class="form-control bg-transparent" placeholder="Año Hasta" maxlength="4" />
                                <span asp-validation-for="AnioHasta" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdTipoV" class="col-form-label text-gray-600 required">Selecciona un Tipo de Vehículo</label>
                                <select asp-for="IdTipoV" asp-items="new SelectList(Model.TipoVehiculoView, nameof(VehiculoDetalleViewModel.TipoVehiculoViewModel.TipoUnidadId), nameof(VehiculoDetalleViewModel.TipoVehiculoViewModel.NombreTipoId), Model.IdTipoV)" class="form-control">
                                    <option value="">Selecciona un Tipo de Vehículo</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="IdTipoV"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="KmGarantia" class="col-form-label text-gray-600 required">Kilómetros de Garantía</label>
                                <input asp-for="KmGarantia" type="text" inputmode="numeric" class="form-control bg-transparent" placeholder="Kilómetros de Garantía" maxlength="8" />
                                <span asp-validation-for="KmGarantia" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="MesGarantia" class="col-form-label text-gray-600 required">Meses de Garantía</label>
                                <input asp-for="MesGarantia" type="text" inputmode="numeric" class="form-control bg-transparent" placeholder="Meses de Garantía" maxlength="2" />
                                <span asp-validation-for="MesGarantia" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" id="kt_modelo_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/modelo/add.js"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}