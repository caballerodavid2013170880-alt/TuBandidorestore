@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
    ViewData["Title"] = "Modelo";
}

@model SUVAN.BackOffice.Database.Entities.Modelo

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Modelo);



    if (permisosPagina == null)

    {

        return;

    }



    var isAgregarText = Model.IdModelo == 0 ? "Agregar" : "Editar";
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <a href="~/Modelo/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0">
                    <i class="ki-duotone ki-left fs-1 pe-5"></i>
                    <span>@isAgregarText Modelo</span>
                </a>
            </div>
        </div>
    </div>
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">
        <div class="card">
            <div class="card-body py-4">
                <form class="form w-100" novalidate="novalidate" id="kt_modelo_in_form" data-kt-redirect-url="/" asp-controller="Modelo" asp-action="AgregarModelo" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdModelo" type="hidden" />

                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdMarca" class="col-form-label text-gray-600 required">Id Marca</label>
                                <input asp-for="IdMarca" class="form-control bg-transparent" placeholder="ID de la marca" />
                                <span asp-validation-for="IdMarca" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="Descrip" class="col-form-label text-gray-600 required">Descripción</label>
                                <input asp-for="Descrip" class="form-control bg-transparent" placeholder="Descripción del modelo" />
                                <span asp-validation-for="Descrip" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="ADesde" class="col-form-label text-gray-600 required">Año Desde</label>
                                <input asp-for="ADesde" class="form-control bg-transparent" type="number" placeholder="Año desde" />
                                <span asp-validation-for="ADesde" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="AHasta" class="col-form-label text-gray-600 required">Año Hasta</label>
                                <input asp-for="AHasta" class="form-control bg-transparent" type="number" placeholder="Año hasta" />
                                <span asp-validation-for="AHasta" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="IdTipoV" class="col-form-label text-gray-600 required">Id Tipo Vehículo</label>
                                <input asp-for="IdTipoV" class="form-control bg-transparent" placeholder="Tipo de vehículo" />
                                <span asp-validation-for="IdTipoV" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="KmGaran" class="col-form-label text-gray-600 required">Kilómetros Garantía</label>
                                <input asp-for="KmGaran" class="form-control bg-transparent" type="number" placeholder="Kilómetros de garantía" />
                                <span asp-validation-for="KmGaran" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="MesGara" class="col-form-label text-gray-600 required">Meses Garantía</label>
                                <input asp-for="MesGara" class="form-control bg-transparent" type="number" placeholder="Meses de garantía" />
                                <span asp-validation-for="MesGara" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-3">
                                <label asp-for="TipoEje" class="col-form-label text-gray-600 required">Tipo de Eje</label>
                                <input asp-for="TipoEje" class="form-control bg-transparent" placeholder="Tipo de eje" />
                                <span asp-validation-for="TipoEje" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" id="kt_modelo_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!--end::Content-->
@section scripts {
    <script src="~\js\logistica\modelo\add.js"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}