@using SUVAN.BackOffice.Models.ViewModel.Configuracion
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
  ViewData["Title"] = "Chofer y unidad";
}

@model ChoferUnidadViewModel
@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.choferUnidad);
  if (permisosPagina == null)
  {
    return;
  }
}
<style>
  .calendar {
    display: flex;
    flex-wrap: wrap;
  }

    .calendar .month {
      margin: 25px;
      border: 1px solid #e1e1e1;
      padding: 20px;
      border-radius: 20px;
    }

    .calendar .week {
      display: flex;
      justify-content: space-between;
      margin-bottom: 5px;
    }

    .calendar .dayname {
      width: 30px;
      height: 30px;
      margin: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #99A1B7;
    }

    .calendar .day {
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      border-radius: 50%;
    }

    .calendar .empty {
      width: 30px;
      height: 30px;
      /* margin: 2px; */
    }

    .calendar .inactive {
      background-color: #eee;
      color: #555;
      cursor: not-allowed;
    }

    .calendar .selected {
      background-color: #00b561;
      color: #fff;
    }

    .calendar .active {
      background-color: #188ab3;
      color: #fff;
    }

</style>
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <a href="~/choferunidad" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
          <i class="ki-duotone ki-left fs-1 pe-5">
          </i>
          <span>Asignación de chofer y unidad</span>
        </a>

        <!--end::Title-->

      </div>
      <!--end::Page title-->

    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <input type="hidden" asp-for="RutasJson" />
    @* <input type="hidden" asp-for="RutaId" /> *@
    <input type="hidden" asp-for="CorridaId" />
    <!--begin::Card-->
    <div class="card">

      <!--begin::Card body-->
      <div class="card-body py-4">
        <div class="row">
          <div class="col-sm-6">
            <div class="fv-row mb-8">
              <label class="col-sm-2 col-form-label text-gray-600 ">Ruta</label>
              <div class="col-sm-10">
                <select asp-for="RutaId" asp-items="@(new SelectList(Model.Rutas, "RutaId", "Nombre"))" class="form-control" data-control="select2" data-placeholder="Seleccione">
                  <option value="">Selecciona una ruta</option>
                </select>

                @* <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <span asp-validation-for="TipoUnidadId"></span>
                </div> *@

              </div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="fv-row mb-8">
              <label class="col-sm-2 col-form-label text-gray-600 ">Horario</label>
              <div class="col-sm-6">
                <select id="HorarioId" class="form-control">
                  <option value="">Selecciona un horario</option>
                </select>
                @*  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <span asp-validation-for="Placas"></span>
                </div> *@

              </div>
            </div>
          </div>

        </div>
      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
    <!--begin::Card-->
    <div class="card mt-10">
      <!--begin::Card header-->
      <div class="card-header border-0 pt-6">
        <!--begin::Card title-->
        <div class="card-title w-100">


          <!--begin::Toolbar container-->
          <div class="container-fluid d-flex align-items-stretch">
            <!--begin::Toolbar wrapper-->
            <div class="d-flex flex-stack flex-wrap gap-4 w-100">
              <!--begin::Page title-->
              <div class=" d-flex flex-row justify-content-center gap-4 me-3">
                <!--begin::Title-->
                <span class="text-dark fw-bold fs-3 m-0 cursor-pointer" id="calendar-subtract-year"><</span>
                <span class="text-dark fw-bold fs-3 m-0" id="canlendar-current-year">2024</span>
                <span class="text-dark fw-bold fs-3 m-0 cursor-pointer" id="calendar-sum-year">></span>

                <!--end::Title-->

              </div>
              <!--end::Page title-->
              <!--begin::Actions-->
              <div class="d-flex align-items-center gap-2 gap-lg-3">
                @if (permisosPagina!.Agregar)
                {
                  <button id="modal-asignar" class="btn btn-flex btn-outline btn-outline-primary btn-active-color-primary bg-body h-40px fs-7 fw-bold">Asignar</button>
                }

              </div>
              <!--end::Actions-->
            </div>
            <!--end::Toolbar wrapper-->
          </div>
          <!--end::Toolbar container-->


        </div>
        <!--begin::Card title-->

      </div>
      <!--end::Card header-->
      <!--begin::Card body-->
      <div class="card-body">
        <div id="calendar-container" class="calendar">
        </div>
      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>


<div class="modal modal-xl fade" tabindex="-1" id="kt_modal_asignar">
  <div class="modal-dialog">
    <div class="modal-content" id="modal_body_asignacion">

      <div class="modal-header">
        <h3 class="modal-title">Asignación</h3>

        <!--begin::Close-->
        <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
          <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
        </div>
        <!--end::Close-->
      </div>

      <div class="modal-body">
        <div class="row">
          <div class="col-md-6">

            <div class="card mt-2">

              <!--begin::Card body-->
              <div class="card-body ">

                <div class="row">
                  <div class="col-md-12">
                    <div class="fv-row mb-8">
                      <label class="col-sm-12 col-form-label text-gray-600 required">Operador</label>
                      <div class="col-sm-10">
                        <select asp-for="ConductorId" asp-items="@(new SelectList(Model.Conductores, "ChoferId", "Nombre"))" class="form-control" data-control="select2" data-placeholder="Selecciona un Operador" data-dropdown-parent="#kt_modal_asignar">
                          <option></option>
                        </select>

                      </div>
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-12 my-4">
                    <div class="fv-row mb-8">
                      <label class="col-sm-12 col-form-label text-gray-600 required">Vehículo</label>
                      <div class="col-sm-10">
                        <select asp-for="VehiculoId" asp-items="@(new SelectList(Model.Vehiculos, "UnidadId", "Descripcion"))" class="form-control" data-control="select2" data-placeholder="Selecciona un vehículo" data-dropdown-parent="#kt_modal_asignar">
                          <option></option>
                        </select>

                      </div>
                    </div>
                  </div>
                </div>

                <div class="row">
                  <div class="col-md-12 text-end">
                    <button type="button" class="btn btn-sm btn-outline btn-outline-primary" id="btn_agregar_asignacion">Agregar</button>
                  </div>
                </div>
              </div>
              <!--end::Card body-->
            </div>
          </div>
          <div class="col-md-6">
            <div class="card mt-2">

              <!--begin::Card body-->
              <div class="card-body ">
                <div id="listado-operadores-container">
                  @*   <div class="d-flex flex-row gap-4 mb-4">
                  <span class="text-gray-900">Salvador Silva</span>
                  <span class="text-gray-500">Nissan - AS90AS</span>
                  <a class=" ms-auto btn btn-icon btn-active-light-danger w-15px h-15px">
                  <i class="ki-outline ki-trash fs-3"></i>
                  </a>
                  </div>
                  <div class="d-flex flex-row  gap-4 mb-4">
                  <span class="text-gray-900">Salvador Silva</span>
                  <span class="text-gray-500">Nissan - AS90AS</span>
                  <a class="ms-auto btn btn-icon btn-active-light-danger w-15px h-15px">
                  <i class="ki-outline ki-trash fs-3"></i>
                  </a>
                  </div> *@
                </div>
              </div>
              <!--end::Card body-->
            </div>
          </div>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
        <button type="submit" class="btn btn-primary" id="btn-guardar-asignacion">Guardar</button>
      </div>

    </div>
  </div>
</div>



<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/choferunidad/add.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}
