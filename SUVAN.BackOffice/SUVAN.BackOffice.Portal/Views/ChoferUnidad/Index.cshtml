@using SUVAN.BackOffice.Models.ViewModel.Configuracion
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
  ViewData["Title"] = "Chofer y unidad";
}

@model ChoferUnidadViewModel
@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.choferUnidad);
  if (permisosPagina == null)
  {
    return;
  }
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Chofer y unidad</h1>
        <!--end::Title-->

      </div>
      <!--end::Page title-->
      <!--begin::Actions-->
      <div class="d-flex align-items-center gap-2 gap-lg-3">
        @if (permisosPagina!.Agregar)
        {
          <a href="~/choferunidad/agregar" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Agregar chofer unidad</a>
        }
        @if (permisosPagina!.Agregar)
        {
          <a href="~/choferunidad/reasignar" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Reasingar chofer unidad</a>
        }
      </div>
      <!--end::Actions-->
    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card mb-5">

      <!--begin::Card body-->
      <div class="card-body py-4">
        <form class="form w-100" novalidate="novalidate" id="kt_reporte_in_form" data-kt-redirect-url="/" asp-controller="ChoferUnidad" asp-action="Index" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="RutasJson" />
          <input type="hidden" asp-for="IdHoSeleccionado" />
          <div class="fv-row mb-8">
            <div class="col-sm-12">
              <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <div asp-validation-summary="All"></div>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-sm-4">
              <div class="fv-row mb-8">
                <label class="col-sm-12 col-form-label text-gray-600 ">Ruta</label>
                <div class="col-sm-12">
                  <select asp-for="RutaId" asp-items="@(new SelectList(Model.Rutas, "RutaId", "Nombre"))" class="form-control" data-control="select2" data-placeholder="Seleccione">
                    <option value="">Selecciona una ruta</option>
                  </select>

                </div>
              </div>
            </div>
            <div class="col-sm-4">
              <div class="fv-row mb-8">
                <label class="col-sm-12 col-form-label text-gray-600 ">Horario</label>
                <div class="col-sm-12">
                  <select asp-for="HorarioId" class="form-control">
                    <option value="">Selecciona un horario</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div class="mb-10 text-end">
            <button type="submit" id="kt_reporte_in_submit" class="btn btn-primary">
              <!--begin::Indicator label-->
              <span class="indicator-label">Buscar</span>
              <!--end::Indicator label-->
              <!--begin::Indicator progress-->
              <span class="indicator-progress">
                Por favor espere...
                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
              </span>
              <!--end::Indicator progress-->
            </button>
          </div>
        </form>
      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
    <!--begin::Card-->
    <div class="card">
      <!--begin::Card header-->
      <div class="card-header align-items-center py-5 gap-2 gap-md-5">
        <!--begin::Card title-->
        <div class="card-title">
          <!--begin::Search-->
          <div class="d-flex align-items-center position-relative my-1">
            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
            <input type="text" data-kt-reporte-table-filter="search" class="form-control form-control-solid w-450px ps-13" placeholder="Buscar" />
          </div>
          <!--end::Search-->
        </div>

      </div>
      <!--end::Card header-->
      <!--begin::Card body-->
      <div class="card-body py-4">
        <div class="table-responsive">
          <!--begin::Table-->
          <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_reporte_table">
            <thead>
              <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">

                <th class="min-w-225px">Conductor</th>
                <th class="min-w-225px">Unidad</th>
                <th class="min-w-125px">Horario</th>
                <th class="min-w-125px">Fecha</th>
              </tr>
            </thead>
            <tbody class="text-gray-600 fw-semibold">

              @foreach (var item in Model.CorridaAsignacion)
              {
                <tr>
                  <td>
                    @item.Conductor
                  </td>
                  <td>
                    @item.Vehiculo
                  </td>
                  <td>
                    @item.Horario
                  </td>
                  <td>
                    @foreach (var fecha in item.Fechas)
                    {
                      <span class="badge badge-light-primary p-2 m-1">@Convert.ToDateTime(fecha).ToString("dd/MM/yyyy")</span>
                    }
                  </td>

                </tr>

              }

            </tbody>

          </table>
          <!--end::Table-->
        </div>
      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/choferunidad/table.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}
