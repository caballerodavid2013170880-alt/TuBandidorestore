@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
  ViewData["Title"] = "Usuarios";
}
@model List<SUVAN.BackOffice.Database.Entities.Admin>

@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.usuarios);
  if (permisosPagina == null)
  {
    return;
  }
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Usuarios</h1>
        <!--end::Title-->

      </div>
      <!--end::Page title-->
      <!--begin::Actions-->
      <div class="d-flex align-items-center gap-2 gap-lg-3">
        @if (permisosPagina!.Agregar)
        {
          <a href="~/usuarios/agregar" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Agregar Usuario</a>
        }
      </div>
      <!--end::Actions-->
    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card">
      <!--begin::Card header-->
      <div class="card-header border-0 pt-6">
        <!--begin::Card title-->
        <div class="card-title">
          <!--begin::Search-->
          <div class="d-flex align-items-center position-relative my-1">
            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
            <input type="text" data-kt-user-table-filter="search" class="form-control form-control-solid w-450px ps-13" placeholder="Buscar" />
          </div>
          <!--end::Search-->
        </div>
        <!--begin::Card title-->

      </div>
      <!--end::Card header-->
      <!--begin::Card body-->
      <div class="card-body py-4">
        <!--begin::Table-->
        <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_users">
          <thead>
            <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">

              <th class="min-w-125px">Nombre</th>
              <th class="min-w-125px">Email</th>
              <th class="min-w-125px">Activo</th>

              <th class="text-end min-w-100px">Acciones</th>
            </tr>
          </thead>
          <tbody class="text-gray-600 fw-semibold">

            @foreach (var usuario in Model)
            {
              <tr>
                <td>
                  <input type="hidden" data-kt-user-table-filter="row_id" value="@usuario.Idadmin" />
                  @usuario.Nombre
                </td>
                <td>
                  @usuario.Email
                </td>
                <td>
                  @{
                    var activo = usuario.Activo == 1 ? "Si" : "No";
                  }
                  @activo
                </td>

                <td class="text-end">

                  @if (permisosPagina!.Editar)
                  {
                    <a href="~/usuarios/agregar/@usuario.Idadmin" class="btn btn-icon btn-active-light-primary w-30px h-30px">
                      <i class="ki-outline ki-pencil fs-3"></i>
                    </a>
                  }
                  @if (permisosPagina!.Eliminar)
                  {
                    if (usuario.Activo == 1)
                    {
                      <a href="#" class="btn btn-icon btn-active-light-primary w-30px h-30px" data-kt-user-delete-item="@usuario.Idadmin" data-kt-user-table-filter="delete_row">
                        <i class="ki-outline ki-trash fs-3"></i>
                      </a>

                    }
                  }
                </td>
              </tr>

            }
          </tbody>
        </table>
        <!--end::Table-->
      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {

  <script src="~/js/seguridad/usuarios/table.js" asp-append-version="true"></script>
  <script src="~/js/seguridad/usuarios/export-users.js" asp-append-version="true"></script>
  <script src="~/js/seguridad/usuarios/add.js" asp-append-version="true"></script>

}