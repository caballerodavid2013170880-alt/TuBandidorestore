@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
  ViewData["Title"] = "Tipo de unidad";
}

@model AgregarTipoUnidadViewModel
@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.tipovehiculo);
  if (permisosPagina == null)
  {
    return;
  }

  var isAgaregarText = Model.TipoUnidadId == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <a href="~/configuracion/tipounidad" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
          <i class="ki-duotone ki-left fs-1 pe-5">
          </i>
          <span>@isAgaregarText tipo de unidad</span>
        </a>
        <!--end::Title-->

      </div>
      <!--end::Page title-->

    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card">

      <!--begin::Card body-->
      <div class="card-body py-4">


        <form class="form w-100" novalidate="novalidate" id="kt_tipounidad_in_form" data-kt-redirect-url="/" asp-controller="Configuracion" asp-action="AgregarTipoUnidad" method="post">
          @Html.AntiForgeryToken()
          <input asp-for="TipoUnidadId" type="hidden" />

          <div class="fv-row mb-8">
            <div class="col-sm-12">
              <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <div asp-validation-summary="All"></div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Nombre" class="col-sm-2 col-form-label text-gray-600 required">Nombre</label>
                <div class="col-sm-6">
                  <input asp-for="Nombre" class="form-control bg-transparent" placeholder="Tipo de unidad" maxlength="45" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Nombre"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Asientos" class="col-sm-2 col-form-label text-gray-600 required">Asientos</label>
                <div class="col-sm-6">
                  <input asp-for="Asientos" class="form-control bg-transparent" placeholder="Número de asientos" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Asientos"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>

          <div class="fv-row mb-8">
            <div class="col-sm-4">
              <div class="form-check">
                <label asp-for="Activo" class="form-check-label"></label>
                <input asp-for="Activo" class="form-check-input" />
              </div>
            </div>
          </div>

          <div class="mb-10 text-end">

            <button type="submit" id="kt_tipounidad_in_submit" class="btn btn-primary">
              <!--begin::Indicator label-->
              <span class="indicator-label">Guardar</span>
              <!--end::Indicator label-->
              <!--begin::Indicator progress-->
              <span class="indicator-progress">
                Por favor espere...
                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
              </span>
              <!--end::Indicator progress-->
            </button>
          </div>
        </form>


      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/tipounidad/add.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}