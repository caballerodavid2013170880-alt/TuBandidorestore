ï»¿@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Models.Configuracion.Tarifas;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
  ViewData["Title"] = "Tarifas";
}
@model EstablecerTarifaViewModel

@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.tarifas);
  if (permisosPagina == null)
  {
    return;
  }
}

<div id="kt_app_toolbar" class="app-toolbar ">
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Establecer tarifas</h1>
      </div>
    </div>
  </div>
</div>

<div id="kt_app_content" class="app-content flex-column-fluid">
  <div id="kt_app_content_container" class="app-container container-fluid">
    <div class="card">
      <div class="card-body py-4">
        <div class="fv-row row">
          <div class="col-md-4">
            <label asp-for="RutaId" class="col-form-label text-gray-600 required">Elige la ruta</label>
            <select asp-for="RutaId" asp-items="new SelectList(Model.Rutas, nameof(RutaTipoTarifaModel.RutaId), nameof(RutaTipoTarifaModel.RutaNombre), Model.Ruta)" class="form-control" data-control="select2" data-placeholder="Seleccione">
              <option value="">Seleccione..</option>
            </select>
            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
              <span asp-validation-for="RutaId"></span>
            </div>
          </div>

          <div class="col-md-4">
            <label asp-for="TipoTarifaId" class="col-form-label text-gray-600 required">Elige el tipo tarifa</label>
            <select asp-for="TipoTarifaId" asp-items="new SelectList(Model.TipoTarifas, nameof(TipoTarifaModel.TipoTarifaId), nameof(TipoTarifaModel.Nombre), Model.TipoTarifaId)" class="form-control">
              <option value="">Seleccione..</option>
            </select>
            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
              <span asp-validation-for="TipoTarifaId"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div id="divContentPrecioTarifas" class="app-content flex-column-fluid" style="display:none">
  <div id="divContainerPrecioTarifas" class="app-container container-fluid">
    <div class="card">
      <div class="card-body py-4">
        <h5 class="card-title" id="divTitleMonto"></h5>


        <div class="fv-row row mb-10 justify-content-md-center" id="divTipoFija" style="display:none">
          <div class="col-md-4">
            <label for="TipoTarifaId" class="col-form-label text-gray-600 required">Monto tarifa fija</label>
            <input id="txtMontoTarifaFija" name="txtMontoTarifaFija" class="form-control" />
          </div>
        </div>
        <div class="fv-row row mb-10" id="divTipoEscalonada" style="display:none">
          <div id="contenedorPiramide" class="col-md-8">
          </div>
          <div class="col-md-4 p-3 border bg-light">
            <div class="row justify-content-md-center">
              <div class="col-md-8 mb-5">
                <label class="col-form-label text-gray-600" for="dropTipoCambio">Modificar tarifa general</label>
              </div>
              <div class="col-md-8 mb-5">
                <select class="form-control" id="dropTipoCambio" name="dropTipoCambio">
                  <option value="1">$ Cantidad</option>
                  <option value="2">% Porcentaje</option>
                </select>
              </div>
              <div class="col-md-8 mb-5">
                <input class="form-control input-sm" type="number" placeholder="Valor" id="txtMontoCambio" name="txtMontoCambio" />
              </div>
              <div class="col-md-8 text-center">
                <button class="btn btn-outline btn-outline-dashed btn-outline-primary btn-active-light-primary" type="button" id="btnActualizaPiramide">Modificar</button>
              </div>
            </div>
          </div>
        </div>
        <div class="mb-10 text-center">
          <button type="button" id="btnGuardar" class="btn btn-primary" name="">
            <span class="indicator-label">Guardar</span>
            <span class="indicator-progress">
              Por favor espere...
              <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

@section scripts {

  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>
  <script src="~/assets/js/custom/apps/chat/chat.js"></script>
  <script src="~/assets/js/custom/utilities/modals/upgrade-plan.js" asp-append-version="true"></script>
  <script src="~/assets/js/custom/utilities/modals/create-campaign.js" asp-append-version="true"></script>
  <script charset="windows-1252" src="~/js/configuracion/tarifas/establecetarifa.js"></script>
}