@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
  ViewData["Title"] = "Unidad";
}
@model AgregarUnidadViewModel

@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.unidades);
  if (permisosPagina == null)
  {
    return;
  }
  var isAgaregarText = Model.UnidadId == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <a href="~/configuracion/unidades" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
          <i class="ki-duotone ki-left fs-1 pe-5">
          </i>
          <span>@isAgaregarText unidad</span>
        </a>
        <!--end::Title-->

      </div>
      <!--end::Page title-->

    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card">

      <!--begin::Card body-->
      <div class="card-body py-4">


        <form class="form w-100" novalidate="novalidate" id="kt_unidad_in_form" data-kt-redirect-url="/" asp-controller="Configuracion" asp-action="AgregarUnidad" method="post">
          @Html.AntiForgeryToken()
          <input asp-for="UnidadId" type="hidden" />
          <input asp-for="ServiciosJson" type="hidden" />

          <div class="fv-row mb-8">
            <div class="col-sm-12">
              <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <div asp-validation-summary="All"></div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="TipoUnidadId" class="col-sm-12 col-form-label text-gray-600 required">Tipo de unidad</label>
                <div class="col-sm-12">
                  <select asp-for="TipoUnidadId" asp-items="@(new SelectList(Model.TipoUnidades, "TipoUnidadId", "Nombre"))" class="form-control">
                    <option value="">Selecciona un Tipo de Unidad</option>
                  </select>
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="TipoUnidadId"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Placas" class="col-sm-12 col-form-label text-gray-600 required">Placas</label>
                <div class="col-sm-12">
                  <input asp-for="Placas" class="form-control bg-transparent" placeholder="Placas" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Placas"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="NumeroPoliza" class="col-sm-12 col-form-label text-gray-600 required">Número de póliza</label>
                <div class="col-sm-12">
                  <input asp-for="NumeroPoliza" class="form-control bg-transparent" placeholder="Número de póliza" maxlength="20" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="NumeroPoliza"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="FechaFinSeguro" class="col-sm-12 col-form-label text-gray-600 required">Fecha fin seguro</label>
                <div class="col-sm-12">
                  <input asp-for="FechaFinSeguro" type="date" class="form-control bg-transparent" placeholder="Fecha fin seguro" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="FechaFinSeguro"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Marca" class="col-sm-12 col-form-label text-gray-600 required">Marca</label>
                <div class="col-sm-12">
                  <input asp-for="Marca" class="form-control bg-transparent" placeholder="Marca" maxlength="100" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Marca"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Modelo" class="col-sm-12 col-form-label text-gray-600 required">Modelo</label>
                <div class="col-sm-12">
                  <input asp-for="Modelo" class="form-control bg-transparent" placeholder="Modelo" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Modelo"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="NumeroEconomico" class="col-sm-12 col-form-label text-gray-600 required">Número económico</label>
                <div class="col-sm-12">
                  <input asp-for="NumeroEconomico" class="form-control bg-transparent" placeholder="Número Económico" maxlength="100" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="NumeroEconomico"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="NumeroMotor" class="col-sm-12 col-form-label text-gray-600 required">Número motor</label>
                <div class="col-sm-12">
                  <input asp-for="NumeroMotor" class="form-control bg-transparent" placeholder="Número motor" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="NumeroMotor"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="fv-row mb-8">
            <label asp-for="Vin" class="col-sm-12 col-form-label text-gray-600">VIN</label>
            <div class="col-sm-12">
              <input asp-for="Vin" class="form-control bg-transparent" placeholder="VIN" style="text-transform: uppercase" />
              <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <span asp-validation-for="Vin"></span>
              </div>

            </div>
          </div>

          <div class="fv-row mb-14">
            <div class="col-sm-4">
              <div class="form-check">
                <label asp-for="Activo" class="form-check-label"></label>
                <input asp-for="Activo" class="form-check-input" />
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col">
              <h3>Servicios</h3>
              <hr />
            </div>
          </div>
          <div class="row">
            <div class="col-6">
              <div class="fv-row mb-8">
                <label for="detalle-servicio" class="col-sm-12 col-form-label text-gray-600">Detalle</label>
                <div class="col-sm-12">
                  <input type="text" id="detalle-servicio" class="form-control bg-transparent" placeholder="Detalle" />

                </div>
              </div>
            </div>
            <div class="col">
              <div class="fv-row mb-8">
                <label for="fecha-servicio" class="col-sm-12 col-form-label text-gray-600">Fecha servicio</label>
                <div class="col-sm-12">
                  <input type="date" id="fecha-servicio" class="form-control bg-transparent" placeholder="Fecha servicio" />
                </div>
              </div>
            </div>
            <div class="col d-flex align-items-center">
              <button type="button" id="agregar-servicio" class="btn btn-flex btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">
                <i class="ki-duotone ki-plus-circle mx-1">
                  <span class="path1"></span>
                  <span class="path2"></span>
                </i>  Agregar servicio
              </button>
            </div>

          </div>

          <div class="row">
            <div class="col">
              <div id="servicios-list-container"></div>
            </div>
          </div>

          <div class="my-10 text-end">

            <button type="submit" id="kt_unidad_in_submit" class="btn btn-primary">
              <!--begin::Indicator label-->
              <span class="indicator-label">Guardar</span>
              <!--end::Indicator label-->
              <!--begin::Indicator progress-->
              <span class="indicator-progress">
                Por favor espere...
                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
              </span>
              <!--end::Indicator progress-->
            </button>
          </div>
        </form>


      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/unidad/add.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}