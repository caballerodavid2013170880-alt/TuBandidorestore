@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
    ViewData["Title"] = "Departamentos";
}

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.empresas);
    if (permisosPagina == null)
    {
        return;
    }
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">@ViewData["Title"]</h1>
            </div>
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                @if (permisosPagina!.Agregar)
                {
                    <a href="~/configuracion/agregardepartamento" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Agregar departamento</a>
                }
            </div>
        </div>
    </div>
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">
            <!-- Filtros para Jerarquía -->
            <div class="card-header border-0 pt-6">
                <div class="card-title w-100 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <!-- Selects para filtrar (Región, Planta, Zona, Depósito) si la UI los requiere,
                             para simplificar se omiten y se manejan desde DataTables o se asume carga por defecto -->
                        <div class="d-flex align-items-center position-relative my-1">
                            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                            <input type="text" data-kt-depto-table-filter="search" class="form-control form-control-solid w-250px ps-13" placeholder="Buscar Depto" />
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card-body py-4">
                <!--begin::Table-->
                <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_depto">
                    <thead>
                        <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                            <th class="min-w-100px">ID Región</th>
                            <th class="min-w-100px">ID Planta</th>
                            <th class="min-w-100px">ID Zona</th>
                            <th class="min-w-100px">ID Depósito</th>
                            <th class="min-w-100px">ID Depto</th>
                            <th class="min-w-150px">Descripción</th>
                            <th class="min-w-150px">Responsable</th>
                            <th class="text-end min-w-100px">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 fw-semibold">
                        <!-- El contenido será cargado vía AJAX o renderizado si pasamos el Modelo -->
                    </tbody>
                </table>
                <!--end::Table-->
            </div>
        </div>
        <!--end::Card-->
    </div>
</div>
<!--end::Content-->
@section scripts {
    <script>
        var puedeEditar = @(permisosPagina!.Editar.ToString().ToLower());
    </script>
    <script src="~/js/configuracion/depto/table.js" asp-append-version="true"></script>
}
