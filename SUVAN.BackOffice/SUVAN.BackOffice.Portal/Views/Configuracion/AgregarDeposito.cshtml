@using SUVAN.BackOffice.Models.Facturacion
@using SUVAN.BackOffice.Models.ViewModel;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Depósito";
}

@model DepositoViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.empresas);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.id_deposi == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <a href="~/configuracion/empresas" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText @ViewData["Title"]</span>
                </a>
                <!--end::Title-->

            </div>
            <!--end::Page title-->

        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">

            <!--begin::Card body-->
            <div class="card-body py-4">


                <form class="form w-100" novalidate="novalidate" id="kt_deposito_in_form" data-kt-redirect-url="/" asp-controller="Configuracion" asp-action="AgregarDeposito" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="id_empresa" type="hidden" value="@User.GetEmpresaId()" />
                    <!-- <input asp-for="id_region" type="hidden" /> -->
                    <input asp-for="id_deposi" type="hidden" />
                    <!--<input asp-for="id_planta" type="hidden" /> -->
                    <!--<input asp-for="id_zona" type="hidden" /> -->

                    <div class="fv-row mb-8">
                        <div class="col-sm-12">
                            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                <div asp-validation-summary="All"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-4">
                            <div class="fv-row mb-8">
                                <label asp-for="id_region" class="col-form-label text-gray-600 required">Elige la región</label>
                                <select asp-for="id_region" asp-items="@(new SelectList(Model.ListadoRegiones, "Id", "Nombre", Model.id_region))" class="form-control">  <!--nameof(RegionModel.Id), nameof(RegionModel.Nombre), Model.id_region))"-->
                                    <option value="0">Seleccione una región... </option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="id_region"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="fv-row mb-8">
                                <label asp-for="id_planta" class="col-form-label text-gray-600 required">Elige la planta</label>
                                <select asp-for="id_planta" asp-items="@(new SelectList(Model.ListadoPlantas, "Id", "Nombre", Model.id_planta))" class="form-control"> <!--nameof(RegionModel.Id), nameof(RegionModel.Nombre), Model.id_region))"-->
                                    <option value="0">Seleccione una planta... </option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="id_planta"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="fv-row mb-8">
                                <label asp-for="id_zona" class="col-form-label text-gray-600 required">Elige la zona</label>
                                <select asp-for="id_zona" asp-items="@(new SelectList(Model.ListadoZonas, "Id", "Nombre", Model.id_zona))" class="form-control"> <!--nameof(RegionModel.Id), nameof(RegionModel.Nombre), Model.id_region))"-->
                                    <option value="0">Seleccione una zona... </option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="id_zona"></span>
                                </div>
                            </div>
                        </div>
                    </div> 



                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="descrip" class="col-sm-12 col-form-label text-gray-600 required">Nombre</label>
                                <div class="col-sm-12">
                                    <input asp-for="descrip" class="form-control bg-transparent" placeholder="Nombre" maxlength="250" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="descrip"></span>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="direc" class="col-sm-12 col-form-label text-gray-600 required">Dirección</label>
                                <div class="col-sm-12">
                                    <input asp-for="direc" class="form-control bg-transparent" placeholder="Dirección" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="direc"></span>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>


                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="ciudad" class="col-sm-12 col-form-label text-gray-600 required">Ciudad</label>
                                <div class="col-sm-12">
                                    <input asp-for="ciudad" class="form-control bg-transparent" placeholder="Ciudad" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="ciudad"></span>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="respon" class="col-sm-12 col-form-label text-gray-600 required">Respon</label>
                                <div class="col-sm-12">
                                    <input asp-for="respon" class="form-control bg-transparent" placeholder="Respon" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="respon"></span>
                                    </div>

                                </div>
                            </div>
                        </div>
                        
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="tel" class="col-sm-12 col-form-label text-gray-600 required">Teléfono</label>
                                <div class="col-sm-12">
                                    <input asp-for="tel" class="form-control bg-transparent" placeholder="Teléfono" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="tel"></span>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="loc_for" class="col-sm-12 col-form-label text-gray-600 required">Loc For</label>
                                <div class="col-sm-12">
                                    <input asp-for="loc_for" class="form-control bg-transparent" placeholder="Loc For" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="loc_for"></span>
                                    </div>

                                </div>
                            </div>
                        </div>
                        
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="r_person" class="col-sm-12 col-form-label text-gray-600 required">r person</label>
                                <div class="col-sm-12">
                                    <input asp-for="r_person" class="form-control bg-transparent" placeholder="r person" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="r_person"></span>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="desc_corta" class="col-sm-12 col-form-label text-gray-600 required">Desc corta</label>
                                <div class="col-sm-12">
                                    <input asp-for="desc_corta" class="form-control bg-transparent" placeholder="Desc corta" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="desc_corta"></span>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="cp" class="col-sm-12 col-form-label text-gray-600 required">Código Postal</label>
                                <div class="col-sm-12">
                                    <input asp-for="cp" class="form-control bg-transparent" placeholder="Código Postal" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="cp"></span>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="rfc" class="col-sm-12 col-form-label text-gray-600 required">RFC</label>
                                <div class="col-sm-12">
                                    <input asp-for="rfc" class="form-control bg-transparent" placeholder="RFC" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="rfc"></span>
                                    </div>

                                </div>
                            </div>
                        </div>
                                
                    </div>

                    <div class="mb-10 text-end">

                        <button type="submit" id="kt_deposito_in_submit" class="btn btn-primary">
                            <!--begin::Indicator label-->
                            <span class="indicator-label">Guardar</span>
                            <!--end::Indicator label-->
                            <!--begin::Indicator progress-->
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                            <!--end::Indicator progress-->
                        </button>
                    </div>
                </form>


            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/configuracion/depositos/add.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>

}