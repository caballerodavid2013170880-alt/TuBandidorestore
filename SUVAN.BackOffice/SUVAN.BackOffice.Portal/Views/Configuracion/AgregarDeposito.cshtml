@using SUVAN.BackOffice.Models.ViewModel;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Depósito";
}

@model DepositoViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.empresas);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgregarText = Model.id_deposito == 0 ? "Agregar" : "Editar";
    var regiones = ViewBag.Regiones as List<SUVAN.BackOffice.Database.Entities.Region> ?? new List<SUVAN.BackOffice.Database.Entities.Region>();
    var plantas = ViewBag.Plantas as List<SUVAN.BackOffice.Database.Entities.Plantum> ?? new List<SUVAN.BackOffice.Database.Entities.Plantum>();
    var zonas = ViewBag.Zonas as List<SUVAN.BackOffice.Database.Entities.Zona> ?? new List<SUVAN.BackOffice.Database.Entities.Zona>();
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <a href="~/configuracion/depositos" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgregarText @ViewData["Title"]</span>
                </a>
                <!--end::Title-->

            </div>
            <!--end::Page title-->

        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">

            <!--begin::Card body-->
            <div class="card-body py-4">

                <form class="form w-100" novalidate="novalidate" id="kt_deposito_in_form" data-kt-redirect-url="/" asp-controller="Configuracion" asp-action="AgregarDeposito" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="id_empresa" type="hidden" value="@User.GetEmpresaId()" />
                    <input asp-for="id_deposito" type="hidden" />

                    <div class="fv-row mb-8">
                        <div class="col-sm-12">
                            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                <div asp-validation-summary="All"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-4">
                            <div class="fv-row mb-8">
                                <label asp-for="id_region" class="col-sm-12 col-form-label text-gray-600 required">Región</label>
                                <div class="col-sm-12">
                                    @if (Model.id_deposito > 0)
                                    {
                                        <input type="hidden" asp-for="id_region" />
                                    }
                                    <select asp-for="id_region" class="form-select" data-control="select2" data-placeholder="Seleccione una región" disabled="@(Model.id_deposito > 0 ? "disabled" : null)">
                                        <option value=""></option>
                                        @foreach (var r in regiones)
                                        {
                                            <option value="@r.IdRegion">@r.Nombre</option>
                                        }
                                    </select>
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="id_region"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-4">
                            <div class="fv-row mb-8">
                                <label asp-for="id_planta" class="col-sm-12 col-form-label text-gray-600 required">Planta</label>
                                <div class="col-sm-12">
                                    @if (Model.id_deposito > 0)
                                    {
                                        <input type="hidden" asp-for="id_planta" />
                                    }
                                    <select asp-for="id_planta" class="form-select" data-control="select2" data-placeholder="Seleccione una planta" disabled="@(Model.id_deposito > 0 ? "disabled" : null)">
                                        <option value=""></option>
                                        @foreach (var p in plantas)
                                        {
                                            <option value="@p.IdPlanta">@p.Nombre</option>
                                        }
                                    </select>
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="id_planta"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-4">
                            <div class="fv-row mb-8">
                                <label asp-for="id_zona" class="col-sm-12 col-form-label text-gray-600 required">Zona</label>
                                <div class="col-sm-12">
                                    @if (Model.id_deposito > 0)
                                    {
                                        <input type="hidden" asp-for="id_zona" />
                                    }
                                    <select asp-for="id_zona" class="form-select" data-control="select2" data-placeholder="Seleccione una zona" disabled="@(Model.id_deposito > 0 ? "disabled" : null)">
                                        <option value=""></option>
                                        @foreach (var z in zonas)
                                        {
                                            <option value="@z.IdZona">@z.NombreZona</option>
                                        }
                                    </select>
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="id_zona"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-12">
                            <div class="fv-row mb-8">
                                <label asp-for="descripcion" class="col-sm-12 col-form-label text-gray-600 required">Descripción</label>
                                <div class="col-sm-12">
                                    <input asp-for="descripcion" class="form-control bg-transparent" placeholder="Descripción del depósito" maxlength="100" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="descripcion"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="responsable" class="col-sm-12 col-form-label text-gray-600">Responsable</label>
                                <div class="col-sm-12">
                                    <input asp-for="responsable" class="form-control bg-transparent" placeholder="Nombre del responsable" maxlength="100" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="responsable"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="fv-row mb-8">
                                <label asp-for="telefono" class="col-sm-12 col-form-label text-gray-600">Teléfono</label>
                                <div class="col-sm-12">
                                    <input asp-for="telefono" class="form-control bg-transparent" placeholder="Teléfono" maxlength="20" />
                                    <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                        <span asp-validation-for="telefono"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-10 text-end">
                        <button type="submit" id="kt_deposito_in_submit" class="btn btn-primary">
                            <!--begin::Indicator label-->
                            <span class="indicator-label">Guardar</span>
                            <!--end::Indicator label-->
                            <!--begin::Indicator progress-->
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                            <!--end::Indicator progress-->
                        </button>
                    </div>
                </form>

            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/configuracion/depositos/add.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}
