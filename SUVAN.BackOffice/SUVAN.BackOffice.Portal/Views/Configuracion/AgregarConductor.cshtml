@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
  ViewData["Title"] = "Conductor";
}

@model AgregarConductorViewModel
@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.conductores);
  if (permisosPagina == null)
  {
    return;
  }
  var isAgaregarText = Model.ConductorId == 0 ? "Agregar" : "Editar";
}
<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <a href="~/configuracion/conductores" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
          <i class="ki-duotone ki-left fs-1 pe-5">
          </i>
          <span>@isAgaregarText Conductor</span>
        </a>
        <!--end::Title-->

      </div>
      <!--end::Page title-->

    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card">

      <!--begin::Card body-->
      <div class="card-body py-4">


        <form class="form w-100" novalidate="novalidate" id="kt_conductor_in_form" data-kt-redirect-url="/" asp-controller="Configuracion" asp-action="AgregarConductor" enctype="multipart/form-data" method="post">
          @Html.AntiForgeryToken()
          <input asp-for="ConductorId" type="hidden" />
          <input asp-for="Imagen64" type="hidden" />

          <div class="fv-row mb-8">
            <div class="col-sm-12">
              <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                <div asp-validation-summary="All"></div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Nombre" class="col-sm-12 col-form-label text-gray-600 required">Nombre</label>
                <div class="col-sm-12">
                  <input asp-for="Nombre" class="form-control bg-transparent" placeholder="Nombre" maxlength="250" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Nombre"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Correo" class="col-sm-12 col-form-label text-gray-600 required">Correo</label>
                <div class="col-sm-12">
                  <input asp-for="Correo" class="form-control bg-transparent" placeholder="Correo" maxlength="250" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Correo"></span>
                  </div>

                </div>
              </div>
            </div>


          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="RFC" class="col-sm-12 col-form-label text-gray-600 required">RFC</label>
                <div class="col-sm-12">
                  <input asp-for="RFC" class="form-control bg-transparent" placeholder="RFC" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="RFC"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Curp" class="col-sm-12 col-form-label text-gray-600 required">CURP</label>
                <div class="col-sm-12">
                  <input asp-for="Curp" class="form-control bg-transparent" placeholder="CURP" maxlength="20" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Curp"></span>
                  </div>

                </div>
              </div>
            </div>


          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Ine" class="col-sm-12 col-form-label text-gray-600 required">INE</label>
                <div class="col-sm-12">
                  <input asp-for="Ine" class="form-control bg-transparent" placeholder="INE" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Ine"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="TipoSangre" class="col-sm-12 col-form-label text-gray-600 required">Tipo de sangre</label>
                <div class="col-sm-12">
                  <input asp-for="TipoSangre" class="form-control bg-transparent" placeholder="Tipo de sangre" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="TipoSangre"></span>
                  </div>

                </div>
              </div>
            </div>



          </div>
          <div class="row">
            <div class="col-sm-12">
              <div class="fv-row mb-8">
                <label asp-for="Direccion" class="col-sm-12 col-form-label text-gray-600 required">Dirección</label>
                <div class="col-sm-12">
                  <input asp-for="Direccion" class="form-control bg-transparent" placeholder="Direccion" maxlength="250" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Direccion"></span>
                  </div>

                </div>
              </div>
            </div>
          </div>
          <div class="row">

            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="NumeroLicencia" class="col-sm-12 col-form-label text-gray-600 required">Numero licencia</label>
                <div class="col-sm-12">
                  <input asp-for="NumeroLicencia" class="form-control bg-transparent" placeholder="Numero licencia" maxlength="20" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="NumeroLicencia"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="TipoLicencia" class="col-sm-12 col-form-label text-gray-600 required">Tipo licencia</label>
                <div class="col-sm-12">
                  <input asp-for="TipoLicencia" class="form-control bg-transparent" placeholder="Tipo licencia" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="TipoLicencia"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="RegimenFiscalId" class="col-sm-12 col-form-label text-gray-600 required">Regimen Fiscal</label>
                <div class="col-sm-12">
                  <select asp-for="RegimenFiscalId" asp-items="@(new SelectList(Model.RegimenFiscal, "Id", "Nombre"))" class="form-control">
                    <option value="">Selecciona un Regimen Fiscal</option>
                  </select>
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="RegimenFiscalId"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Cif" class="col-sm-12 col-form-label text-gray-600 required">CIF</label>
                <div class="col-sm-12">
                  <input asp-for="Cif" class="form-control bg-transparent" placeholder="CIF" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Cif"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="NombreContacto" class="col-sm-12 col-form-label text-gray-600">Nombre contacto</label>
                <div class="col-sm-12">
                  <input asp-for="NombreContacto" class="form-control bg-transparent" placeholder="Nombre contacto" maxlength="250" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="NombreContacto"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="TelefonoContacto" class="col-sm-12 col-form-label text-gray-600">Teléfono contacto</label>
                <div class="col-sm-12">
                  <input asp-for="TelefonoContacto" class="form-control bg-transparent" placeholder="Telefono contacto" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="TelefonoContacto"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="Comisionfija" class="col-sm-12 col-form-label text-gray-600 ">Comisión fija $</label>
                <div class="col-sm-12">
                  <input asp-for="Comisionfija" class="form-control bg-transparent comisionValidator" placeholder="Comisión fija" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="Comisionfija"></span>
                  </div>

                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="ComisionvariableKm" class="col-sm-12 col-form-label text-gray-600 ">Comisión variable Km $</label>
                <div class="col-sm-12">
                  <input asp-for="ComisionvariableKm" class="form-control bg-transparent comisionValidator" placeholder="Comisión variable Km" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="ComisionvariableKm"></span>
                  </div>

                </div>
              </div>
            </div>

          </div>
          <div class="row">
            <div class="col-sm-6">
              <div class="fv-row mb-8">
                <label asp-for="ComisionvariableIngresos" class="col-sm-12 col-form-label text-gray-600 ">Comisión variable Ingresos %</label>
                <div class="col-sm-12">
                  <input asp-for="ComisionvariableIngresos" class="form-control bg-transparent comisionValidator" placeholder="Comisión variable Ingresos" />
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <span asp-validation-for="ComisionvariableIngresos"></span>
                  </div>

                </div>
              </div>
            </div>


          </div>

          <div class="fv-row mb-8">
            <label asp-for="Imagen" class="col-sm-12 col-form-label text-gray-600">Imagen</label>
            <div class="text-muted fs-7">Tipos de archivos permitidos: *.png, *.jpg y *.jpeg</div>
            <!--begin::Card body-->
            <div class="card-body mt-7 pt-0">

              <!--begin::Image input-->
              <!--begin::Image input placeholder-->
              <style>
                .image-input-placeholder {
                  background-image: url('/assets/media/svg/files/blank-image.svg');
                }

                [data-bs-theme="dark"] .image-input-placeholder {
                  background-image: url('/assets/media/svg/files/blank-image-dark.svg');
                }</style>
              <!--end::Image input placeholder-->
              <div class="image-input image-input-empty image-input-outline image-input-placeholder  mb-3" data-kt-image-input="true">
                <!--begin::Preview existing avatar-->
                <div id="image-conductor-wrapper" class="image-input-wrapper w-150px h-150px"></div>
                <!--end::Preview existing avatar-->
                <!--begin::Label-->
                <label class="btn btn-icon btn-circle btn-active-color-primary w-25px h-25px bg-body shadow" data-kt-image-input-action="change" data-bs-toggle="tooltip" title="Cargar Imagen">
                  <i class="ki-outline ki-pencil fs-7"></i>
                  <!--begin::Inputs-->
                  <input asp-for="Imagen" type="file" accept=".png, .jpg, .jpeg" />
                  @* <input type="hidden" name="avatar_remove" /> *@
                  <!--end::Inputs-->
                </label>
                <!--end::Label-->
                <!--begin::Cancel-->
                <span class="btn btn-icon btn-circle btn-active-color-primary w-25px h-25px bg-body shadow" data-kt-image-input-action="cancel" data-bs-toggle="tooltip" title="Cancelar Imagen">
                  <i class="ki-outline ki-cross fs-2"></i>
                </span>
                <!--end::Cancel-->
                <!--begin::Remove-->
                <span class="btn btn-icon btn-circle btn-active-color-primary w-25px h-25px bg-body shadow" data-kt-image-input-action="remove" data-bs-toggle="tooltip" title="Remover Imagen">
                  <i class="ki-outline ki-cross fs-2"></i>
                </span>
                <!--end::Remove-->
              </div>
              <!--end::Image input-->

            </div>
            <!--end::Card body-->
          </div>

          <div class="fv-row mb-8">
            <div class="col-sm-4">
              <div class="form-check">
                <label asp-for="Activo" class="form-check-label"></label>
                <input asp-for="Activo" class="form-check-input" />
              </div>
            </div>
          </div>

          <div class="mb-10 text-end">

            <button type="submit" id="kt_conductor_in_submit" class="btn btn-primary">
              <!--begin::Indicator label-->
              <span class="indicator-label">Guardar</span>
              <!--end::Indicator label-->
              <!--begin::Indicator progress-->
              <span class="indicator-progress">
                Por favor espere...
                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
              </span>
              <!--end::Indicator progress-->
            </button>
          </div>
        </form>


      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/conductores/add.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}