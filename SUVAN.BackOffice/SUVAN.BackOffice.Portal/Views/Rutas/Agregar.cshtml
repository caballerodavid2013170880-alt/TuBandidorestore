@using SUVAN.BackOffice.Models.AppSettingsModels
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@inject Microsoft.Extensions.Options.IOptions<GoogleSettingsOptions> GoogleSettingsOptions

@{
  ViewData["Title"] = "Rutas";
}
@model AgregarRutaViewModel
@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.rutas);
  if (permisosPagina == null)
  {
    return;
  }

  var isAgaregarText = Model.RutaId == 0 ? "Agregar" : "Editar";
}

<style>
  #kt_modal_seleccionar_punto {
    z-index: 1051 !important;
  }

  .pac-container {
    z-index: 1052 !important;
  }

  .badgeMarker {
    position: absolute;
    top: 5px;
    left: 5px;
    background-color: red;
    color: white;
    padding: 5px;
    border-radius: 50%;
  }

  .custom-label {
    position: relative;
    left: 30px; /* Ajusta según sea necesario para colocar la etiqueta al costado */
    top: -10px; /* Ajusta según sea necesario para colocar la etiqueta al costado */
    background-color: white;
    padding: 5px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-weight: bold;
    font-size: 16px;
    z-index: 1;
  }
</style>
