@using SUVAN.BackOffice.Models.ViewModel.Configuracion
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
  ViewData["Title"] = "Variables empresa";
}
@model AgregarVariableViewModel

@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.variablesEmpresa);
  if (permisosPagina == null)
  {
    return;
  }
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Variables por empresa</h1>
        <!--end::Title-->

      </div>
      <!--end::Page title-->

    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>

<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <form class="form w-100" novalidate="novalidate" id="kt_variables_in_form" data-kt-redirect-url="/" asp-controller="Variables" asp-action="Index" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="All" class="text-danger"></div>
      <input asp-for="CantidadVariables" type="hidden" />

      <div class="table-responsive">
        <table class="table">
          <thead>

            <tr class="fw-bold fs-5 text-gray-800">
              <th>Variable de configuración</th>
              <th>Valor</th>
            </tr>
          </thead>
          <tbody>
            @for (var i = 0; i < Model.Variables.Count; i++)
            {
              <tr>
                <td>
                  <span class="fw-bold fs-6 text-gray-600">
                    @Model.Variables[i].Descripcion
                  </span>
                  <input asp-for="Variables[i].Descripcion" type="hidden" />
                </td>

                <td>
                  <div class="fv-row">
                    <input type="hidden" asp-for="Variables[i].VariableId" />
                    <div class="col-sm-6">
                      <input asp-for="Variables[i].Valor" type="text" class="form-control bg-transparent" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Variables[i].Valor"></span>
                      </div>
                    </div>
                  </div>
                </td>

              </tr>
            }
          </tbody>
        </table>
      </div>


      <div class="mb-10 text-end">
        @if (permisosPagina!.Agregar)
        {
          <button type="submit" id="kt_variables_in_submit" class="btn btn-primary">
            <!--begin::Indicator label-->
            <span class="indicator-label">Guardar</span>
            <!--end::Indicator label-->
            <!--begin::Indicator progress-->
            <span class="indicator-progress">
              Por favor espere...
              <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
            </span>
            <!--end::Indicator progress-->
          </button>
        }
      </div>
    </form>
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/variables/addvariablesempresa.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}