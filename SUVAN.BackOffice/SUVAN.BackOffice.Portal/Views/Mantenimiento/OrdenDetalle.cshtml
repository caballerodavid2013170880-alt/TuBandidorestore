@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "OrdenDetalle";
}

@model MantenimientoViewModel
@* @{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.Mantenimiento);
    if (permisosPagina == null)
    {
        return;
    }
} *@


<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <a href="~/Mantenimiento/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>Detalle Orden de Mantenimiento</span>
                </a>
            </div>
        </div>
    </div>
</div>
<div class="container-sm my-5">
    <div class="card shadow col-md-4 mx-auto">
        <div class="row">
            <div class="col-md-6 d-flex justify-content-center">
                <div class="image-container">
                    <style>
                        .checked {
                            color: #004AAD;
                        }

                        .image-input-placeholder {
                            background-image: url('/assets/media/svg/files/blank-image.svg');
                        }

                        [data-bs-theme="dark"] .image-input-placeholder {
                            background-image: url('/assets/media/svg/files/blank-image-dark.svg');
                        }</style>
                    <div class="image-input image-input-empty image-input-outline image-input-placeholder mb-10 mt-10" data-kt-image-input="true">
                        <img alt="Imagen" class="image-input-wrapper w-150px h-150px">
                    </div>
                    <!--end::Image input-->

                </div>
            </div>
            <div class="col-md-4 d-flex align-items-center">
                <div class="info-container">
                    <div>
                        @* <h3>@Model.Nombre</h3> *@
                        <h3>Nombre</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container mt-5">
    <div class="mx-auto d-flex align-items-center">
        <!-- Lista Horizontal -->
        <ul class="nav nav-pills mx-auto d-flex align-items-center" id="listaHorizontal">
            <li class="nav-item">
                <a class="nav-link active" id="ordendetalle-tab" data-bs-toggle="tab" href="#ordendetalle">Orden Detalle</a>
            </li>

            <li class="nav-item">
                <a class="nav-link active" id="datosvehiculo-tab" data-bs-toggle="tab" href="#datosvehiculo">Datos del Vehículo</a>
            </li>
        </ul>
    </div>
    <!-- Contenido de las Pestañas -->
    <div class="container mt-5">
        <div class="tab-content" id="contenidoPestanas">
            <div class="tab-pane fade show active" id="ordendetalle">
            </div>

            <div class="tab-pane fade show active" id="datosvehiculo">
            </div>
        </div>
    </div>
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<!--end::Content-->
@* <script type="text/javascript">
    window.userId = @Model.Idusuario;
</script> *@
@section scripts {
    <script src="~/js/logistica/mantenimiento/mantenimiento.js" asp-append-version="true"></script>
    <script src="~/js/logistica/mantenimiento/navOrdenDetalle.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}
