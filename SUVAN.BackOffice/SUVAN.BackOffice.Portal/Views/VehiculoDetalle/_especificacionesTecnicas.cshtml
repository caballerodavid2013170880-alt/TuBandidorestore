@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Logistica
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Vehiculo Detalles";
}
@model VehiculoDetalleViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoDetalle);
    if (permisosPagina == null)
    {
        return;
    }
}

<div class="card card-bordered mb-5">
    <div class="card-header">
        <h3 class="card-title">Especificaciones Técnicas</h3>
    </div>
    <div class="card-body py-2">
        <div class="row">
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="PesoMinimo" class="col-form-label text-gray-600 required">Peso Mínimo</label>
                    <input asp-for="PesoMinimo" id="PesoMinimo" type="text" class="form-control form-control-sm bg-transparent" placeholder="Peso Mínimo" />
                    <span asp-validation-for="PesoMinimo" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="PesoMaximo" class="col-form-label text-gray-600 required">Peso Máximo</label>
                    <input asp-for="PesoMaximo" id="PesoMaximo" type="text" class="form-control form-control-sm bg-transparent" placeholder="Peso Máximo" />
                    <span asp-validation-for="PesoMaximo" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="VolumenMinimo" class="col-form-label text-gray-600 required">Volumen Mínimo</label>
                    <input asp-for="VolumenMinimo" id="VolumenMinimo" type="text" class="form-control form-control-sm bg-transparent" placeholder="Volumen Mínimo" />
                    <span asp-validation-for="VolumenMinimo" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="VolumenMaximo" class="col-form-label text-gray-600 required">Volumen Máximo</label>
                    <input asp-for="VolumenMaximo" id="VolumenMaximo" type="text" class="form-control form-control-sm bg-transparent" placeholder="Volumen Máximo" />
                    <span asp-validation-for="VolumenMaximo" class="invalid-feedback"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-2 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="TieneCaja" class="col-form-label text-gray-600 required d-block">¿Tiene Caja?</label>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="TieneCaja" value="1" id="radioTieneCajaSi">
                        <label class="form-check-label" for="radioTieneCajaSi">Sí</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="TieneCaja" value="0" id="radioTieneCajaNo">
                        <label class="form-check-label" for="radioTieneCajaNo">No</label>
                    </div>
                    <span asp-validation-for="TieneCaja" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-2 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="NecesitaRemolque" class="col-form-label text-gray-600 required d-block">¿Necesita Remolque?</label>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="NecesitaRemolque" value="1" id="radioRemolqueSi">
                        <label class="form-check-label" for="radioRemolqueSi">Sí</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="NecesitaRemolque" value="0" id="radioRemolqueNo">
                        <label class="form-check-label" for="radioRemolqueNo">No</label>
                    </div>
                    <span asp-validation-for="NecesitaRemolque" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-2 mb-2 d-flex flex-column">
                <label class="invisible">Label</label>
                <button type="button" class="btn btn-primary btn-sm btnModal w-auto" data-idmarca="@Model.IdMarca" data-idmodelo="@Model.IdModelo" title="Ver especificaciones">
                    Especificaciones del modelo
                </button>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-primary btn-sm" onclick="irATabAnterior()">Anterior</button>
            <button type="button" class="btn btn-primary btn-sm btn-next-tab" data-current="especificaciones" data-next="permisoslicencias">Siguiente</button>
        </div>
    </div>
    <div class="modal fade" id="kt_modal_especificaciones" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitulo">Especificaciones del Modelo</h2>
                    <button type="button" class="btn btn-icon" data-bs-dismiss="modal">×</button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-pills mb-3 justify-content-center" id="vehiculoTabsEspecificaciones">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="pill" data-tab="dimensioncapacidad" href="#">Dimensión y Capacidad</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="pill" data-tab="motordesempeno" href="#">Motor y Desempeño</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="pill" data-tab="transmisiontraccion" href="#">Transmisión y Tracción</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="pill" data-tab="datosadicionales" href="#">Datos Adicionales</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="pill" data-tab="imagen" href="#">Imágenes</a>
                        </li>
                    </ul>

                    <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_especificaciones"></table>
                    <div class="tab-content mt-4">
                        <div class="tab-pane tp fade" id="tab-imagen">
                            <div id="imagenesContainer" class="d-flex flex-wrap gap-3 align-items-start"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

</div>

@section scripts {
    <script src="~/js/logistica/vehiculodetalle/navvehiculodetalle.js"></script>
    <script src="~/js/logistica/vehiculodetalle/validaciones.js"></script>
    <script src="~/js/logistica/vehiculodetalle/addmodalespecifi.js"></script>
}