@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
    ViewData["Title"] = "Vehiculo Detalles";
}
@model List<SUVAN.BackOffice.Database.Entities.VehiculoDetalle>

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoDetalle);
    if (permisosPagina == null)
    {
        return;
    }
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <!--begin::Toolbar wrapper-->
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <!--begin::Title-->
                <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Vehículo Detalles</h1>
                <!--end::Title-->

            </div>
            <!--end::Page title-->
            <!--begin::Actions-->
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                @if (permisosPagina!.Agregar)
                {
                    <a href="~/VehiculoDetalle/NavegacionVehiculoDetalle" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Agregar Detalle</a>
                }
            </div>
            <!--end::Actions-->
        </div>
        <!--end::Toolbar wrapper-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Card-->
        <div class="card">
            <!--begin::Card header-->
            <div class="card-header border-0 pt-6">
                <!--begin::Card title-->
                <div class="card-title">
                    <!--begin::Search-->
                    <div class="d-flex align-items-center position-relative my-1">
                        <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                        <input type="text" data-kt-detalle-table-filter="search" class="form-control form-control-solid w-450px ps-13" placeholder="Buscar" />
                    </div>
                    <!--end::Search-->
                </div>
                <!--begin::Card title-->

            </div>
            <!--end::Card header-->
            <!--begin::Card body-->
            <div class="card-body py-4">
                <!--begin::Table-->
                <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_detalle">
                    <thead>
                        <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                            <th class="min-w-100px">Número de Detalle</th>
                            <th class="min-w-100px">Vehiculo</th>
                            <th class="min-w-100px">Marca</th>
                            <th class="min-w-100px">Zona</th>
                            <th class="min-w-100px">Depósito</th>
                            <th class="min-w-125px">Número de Serie</th>
                            <th class="min-w-125px">Número de Motor</th>
                            <th class="min-w-100px">Fecha de Compra</th>
                            <th class="text-end min-w-100px">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 fw-semibold">

                        @foreach (var contenido in Model)
                        {
                            <tr>
                                <td>
                                    @contenido.IdVehiculoDetalle
                                </td>
                                <td>
                                    @contenido.IdVehiculoNavigation.Placas
                                </td>
                                <td>
                                    @contenido.IdMarcaNavigation.Descripcion
                                </td>
                                <td>
                                    @contenido.IdZonaNavigation.NombreZona
                                </td>
                                <td>
                                    @contenido.IdDepositoNavigation.DepositoNombre
                                </td>
                                <td>
                                    @contenido.NumeroSerie
                                </td>
                                <td>
                                    @contenido.NumeroMotor
                                </td>
                                <td>
                                    @contenido.FechaCompra?.ToShortDateString()
                                </td>

                                <td class="text-end">
                                    @if (permisosPagina!.Editar)
                                    {
                                        <a href="~/VehiculoDetalle/NavegacionVehiculoDetalle/@contenido.IdVehiculoDetalle" class="btn btn-icon btn-active-light-primary w-30px h-30px">
                                            <i class="ki-outline ki-pencil fs-3"></i>
                                        </a>
                                    }
                                    @if (permisosPagina!.Eliminar)
                                    {
                                        <a class="btn btn-icon btn-active-light-primary w-30px h-30px" data-kt-detalle-delete-item="@contenido.IdVehiculoDetalle" data-kt-detalle-table-filter="delete_row">
                                            <i class="ki-outline ki-trash fs-3"></i>
                                        </a>
                                    }
                                    <a href="javascript:void(0)" class="btn btn-icon btn-active-light-primary w-30px h-30px eyeModal" data-idvehiculodetalle="@contenido.IdVehiculoDetalle" title="Ver detalle">
                                        <i class="ki-outline ki-eye fs-3"></i>
                                    </a>
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
                <!--end::Table-->
            </div>
            <!--end::Card body-->
            <div class="modal fade" id="kt_modal_eye" tabindex="-1">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h2 id="modalTitulo">Detalle del Vehículo</h2>
                            <button class="btn btn-icon" data-bs-dismiss="modal">×</button>
                        </div>

                        <div class="modal-body">
                            <ul class="nav nav-pills mb-3 justify-content-center" id="vehiculoTabs">
                                <li class="nav-item">
                                    <a class="nav-link active" data-bs-toggle="pill" data-tab="general" href="#">Datos Generales</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" data-bs-toggle="pill" data-tab="ubicacion" href="#">Ubicación y Documentación</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" data-bs-toggle="pill" data-tab="compra" href="#">Compra y Costos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" data-bs-toggle="pill" data-tab="garantia" href="#">Garantía y Estado</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" data-bs-toggle="pill" data-tab="especificaciones" href="#">Especificaciones Técnicas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" data-bs-toggle="pill" data-tab="permisos" href="#">Permisos y Licencias</a>
                                </li>
                            </ul>

                            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_eye"></table>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/vehiculodetalle/table.js"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
    <script src="~/assets/js/custom/utilities/modals/users-search.js" asp-append-version="true"></script>
    <script src="~/js/logistica/vehiculodetalle/addmodal.js"></script>
}