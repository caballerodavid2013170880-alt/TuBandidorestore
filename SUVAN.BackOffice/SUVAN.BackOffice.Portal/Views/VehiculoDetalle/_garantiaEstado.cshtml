@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Logistica
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Vehiculo Detalles";
}
@model VehiculoDetalleViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoDetalle);
    if (permisosPagina == null)
    {
        return;
    }
}

<div class="card card-bordered mb-5">
    <div class="card-header">
        <h3 class="card-title">Garantía y Estado del Vehículo</h3>
    </div>
    <div class="card-body py-2">
        <div class="row">
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="KilometrajeGarantia" class="col-form-label text-gray-600 required">Kilometraje de Garantía</label>
                    <input asp-for="KilometrajeGarantia" class="form-control form-control-sm bg-transparent" placeholder="Kilometraje de Garantía" />
                    <span asp-validation-for="KilometrajeGarantia" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="MesesGarantia" class="col-form-label text-gray-600 required">Meses de Garantía</label>
                    <input asp-for="MesesGarantia" class="form-control form-control-sm bg-transparent" placeholder="Meses de Garantía" />
                    <span asp-validation-for="MesesGarantia" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="FechaBaja" class="col-form-label text-gray-600 required">Fecha de Baja</label>
                    <input asp-for="FechaBaja" class="form-control form-control-sm bg-transparent" placeholder="Fecha de Baja" />
                    <span asp-validation-for="FechaBaja" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="EconomicoAnterior" class="col-form-label text-gray-600 required">Económico Anterior</label>
                    <input asp-for="EconomicoAnterior" class="form-control form-control-sm bg-transparent" placeholder="Económico Anterior" />
                    <span asp-validation-for="EconomicoAnterior" class="invalid-feedback"></span>
                </div>
            </div>
        </div>
        <div class="text-end mt-4">
            <button type="button" class="btn btn-primary btn-sm" onclick="irASiguienteTab('especificaciones')">Siguiente</button>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/logistica/vehiculodetalle/navvehiculodetalle.js"></script>
    <script src="~/js/logistica/vehiculodetalle/add.js"></script>
}