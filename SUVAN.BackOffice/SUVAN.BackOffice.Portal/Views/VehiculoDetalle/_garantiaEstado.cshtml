@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Logistica
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Vehiculo Detalles";
}
@model VehiculoDetalleViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoDetalle);
    if (permisosPagina == null)
    {
        return;
    }
}

<div class="card card-bordered mb-5">
    <div class="card-header">
        <h3 class="card-title">Garantía y Estado del Vehículo</h3>
    </div>
    <div class="card-body py-2">
        <div class="row">
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="IdBaja" class="col-form-label text-gray-600 required">Baja</label>
                    <div class="input-group input-group-sm">
                        <input value="@Model.DescripcionBaja" id="IdBajaVisible" class="form-control form-control-sm bg-transparent bg-light text-muted" placeholder="Baja" readonly disabled />
                        <span class="input-group-text" id="iconoBaja" style="cursor:pointer;">
                            <i class="fas fa-search"></i>
                        </span>
                    </div>
                    <input asp-for="IdBaja" type="hidden" id="IdBaja" name="IdBaja" />
                    <span asp-validation-for="IdBaja" class="invalid-feedback d-block"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="IdCausaBaja" class="col-form-label text-gray-600 required">Causa Baja</label>
                    <div class="input-group input-group-sm">
                        <input value="@Model.DescripcionCausaBaja" id="IdCausaBajaVisible" class="form-control form-control-sm bg-transparent bg-light text-muted" placeholder="Causa Baja" readonly disabled />
                        <span class="input-group-text" id="iconoCausaBaja" style="cursor:pointer;">
                            <i class="fas fa-search"></i>
                        </span>
                    </div>
                    <input asp-for="IdCausaBaja" type="hidden" id="IdCausaBaja" name="IdCausaBaja" />
                    <span asp-validation-for="IdCausaBaja" class="invalid-feedback d-block"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="KilometrajeGarantia" class="col-form-label text-gray-600 required">Kilometraje de Garantía</label>
                    <input asp-for="KilometrajeGarantia" id="KilometrajeGarantia" type="text" class="form-control form-control-sm bg-transparent" placeholder="Kilometraje de Garantía" />
                    <span asp-validation-for="KilometrajeGarantia" class="invalid-feedback"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="MesesGarantia" class="col-form-label text-gray-600 required">Meses de Garantía</label>
                    <input asp-for="MesesGarantia" id="MesesGarantia" type="text" class="form-control form-control-sm bg-transparent" placeholder="Meses de Garantía" />
                    <span asp-validation-for="MesesGarantia" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="FechaBaja" class="col-form-label text-gray-600 required">Fecha de Baja</label>
                    <input value="@Model.FechaBaja" type="text" id="FechaBajaVisible" class="form-control form-control-sm bg-transparent" placeholder="DD/MM/YYYY" readonly/>
                    <input type="hidden" asp-for="FechaBaja" id="FechaBaja" />
                    <span asp-validation-for="FechaBaja" class="invalid-feedback"></span>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-primary btn-sm" onclick="irATabAnterior()">Anterior</button>
            <button type="button" class="btn btn-primary btn-sm btn-next-tab" data-current="garantiaestado" data-next="especificaciones">Siguiente</button>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/logistica/vehiculodetalle/navvehiculodetalle.js"></script>
    <script src="~/js/logistica/vehiculodetalle/add.js"></script>
    <script src="~/js/logistica/vehiculodetalle/validaciones.js"></script>
}