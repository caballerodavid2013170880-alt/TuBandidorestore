                                <input asp-for="VolumenMaximo" class="form-control form-control-sm bg-transparent" placeholder="Volumen Máximo" />
                                <span asp-validation-for="VolumenMaximo" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-bordered mb-5">
                <div class="card-header">
                    <h3 class="card-title">Permisos y Licencias</h3>
                </div>
                <div class="card-body py-2">
                    <div class="row">
                        <div class="col-sm-4 mb-2">
                            <div class="fv-row mb-2">
                                <label asp-for="TipoLicenciaRequerida" class="col-form-label text-gray-600 required">Tipo de Licencia Requerida</label>
                                <input asp-for="TipoLicenciaRequerida" class="form-control form-control-sm bg-transparent" placeholder="Tipo de Licencia Requerida" />
                                <span asp-validation-for="TipoLicenciaRequerida" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-4 mb-2">
                            <div class="fv-row mb-2">
                                <label asp-for="PermisoCargaAceite" class="col-form-label text-gray-600 required">¿Tiene Permiso para Carga de Aceite?</label>
                                <select asp-for="PermisoCargaAceite" class="form-control form-control-sm">
                                    <option value="">Selecciona una Opción</option>
                                    <option value="1">Sí</option>
                                    <option value="0">No</option>
                                </select>
                                <span asp-validation-for="PermisoCargaAceite" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-4 mb-2">
                            <div class="fv-row mb-2">
                                <label asp-for="VigenciaPermisoAceite" class="col-form-label text-gray-600 required">Vigencia del Permiso de Aceite</label>
                                <input asp-for="VigenciaPermisoAceite" class="form-control form-control-sm bg-transparent" placeholder="Vigencia del Permiso de Aceite" />
                                <span asp-validation-for="VigenciaPermisoAceite" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4 mb-2">
                            <div class="fv-row mb-2">
                                <label asp-for="TarjetaCirculacion" class="col-form-label text-gray-600 required">Tarjeta de Circulación</label>
                                <input asp-for="TarjetaCirculacion" class="form-control form-control-sm bg-transparent" placeholder="Tarjeta de Circulación" />
                                <span asp-validation-for="TarjetaCirculacion" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-sm-4 mb-2">
                            <div class="fv-row mb-2">
                                <label asp-for="VigenciaTarjetaCirculacion" class="col-form-label text-gray-600 required">Vigencia de Tarjeta de Circulación</label>
                                <input asp-for="VigenciaTarjetaCirculacion" class="form-control form-control-sm bg-transparent" placeholder="Vigencia de Tarjeta de Circulación" />
                                <span asp-validation-for="VigenciaTarjetaCirculacion" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <button type="submit" id="kt_detalle_in_submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>
        </form>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>

<!-- Ventana modal-->
<div class="modal modal-lg fade" tabindex="-1" id="kt_modal_detalle" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitulo">Título</h5>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body" id="modal-body">
                <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_tabla_detalle">
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
<!--end::Content-->
