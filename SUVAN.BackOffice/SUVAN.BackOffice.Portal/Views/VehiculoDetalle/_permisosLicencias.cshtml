@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Logistica
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Vehiculo Detalles";
}
@model VehiculoDetalleViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoDetalle);
    if (permisosPagina == null)
    {
        return;
    }
}

<div class="card card-bordered mb-5">
    <div class="card-header">
        <h3 class="card-title">Permisos y Licencias</h3>
    </div>
    <div class="card-body py-2">
        <div class="row">
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="TipoLicenciaRequerida" class="col-form-label text-gray-600 required">Tipo de Licencia Requerida</label>
                    <input asp-for="TipoLicenciaRequerida" class="form-control form-control-sm bg-transparent" placeholder="Tipo de Licencia Requerida" />
                    <span asp-validation-for="TipoLicenciaRequerida" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="TarjetaCirculacion" class="col-form-label text-gray-600 required">Tarjeta de Circulación</label>
                    <input asp-for="TarjetaCirculacion" class="form-control form-control-sm bg-transparent" placeholder="Tarjeta de Circulación" />
                    <span asp-validation-for="TarjetaCirculacion" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="VigenciaTarjetaCirculacion" class="col-form-label text-gray-600 required">Vigencia de Tarjeta de Circulación</label>
                    <input value="@Model.VigenciaTarjetaCirculacion" type="text" id="VigenciaTarjetaCirculacionVisible" class="form-control form-control-sm bg-transparent" placeholder="DD/MM/YYYY" readonly/>
                    <input type="hidden" asp-for="VigenciaTarjetaCirculacion" id="VigenciaTarjetaCirculacion" />
                    <span asp-validation-for="VigenciaTarjetaCirculacion" class="invalid-feedback"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-2 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="PermisoCargaAceite" class="col-form-label text-gray-600 required d-block">¿Tiene Permiso para Carga de Aceite?</label>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="PermisoCargaAceite" value="1" id="radioPermisoAceiteSi">
                        <label class="form-check-label" for="radioPermisoAceiteSi">Sí</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="PermisoCargaAceite" value="0" id="radioPermisoAceiteNo">
                        <label class="form-check-label" for="radioPermisoAceiteNo">No</label>
                    </div>
                    <span asp-validation-for="PermisoCargaAceite" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="VigenciaPermisoAceite" class="col-form-label text-gray-600">Vigencia del Permiso de Aceite</label>
                    <input value="@Model.VigenciaPermisoAceite" type="text" id="VigenciaPermisoAceiteVisible" class="form-control form-control-sm bg-transparent" placeholder="DD/MM/YYYY" readonly/>
                    <input type="hidden" asp-for="VigenciaPermisoAceite" id="VigenciaPermisoAceite" />
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-primary btn-sm" onclick="irATabAnterior()">Anterior</button>
            <button type="submit" id="kt_detalle_in_submit" class="btn btn-primary btn-sm">
                <span class="indicator-label">Guardar</span>
                <span class="indicator-progress">
                    Por favor espere...
                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                </span>
            </button>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/logistica/vehiculodetalle/validaciones.js"></script>
}