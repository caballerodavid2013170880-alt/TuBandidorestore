@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
  ViewData["Title"] = "Detalle ruta";
}
@model DetalleRutaViewModel

@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.corridas);
  if (permisosPagina == null)
  {
    return;
  }
  var isAgaregarText = Model.CorridaId == 0 ? "Agregar" : "Editar";
}


<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <a href="~/corridas" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
          <i class="ki-duotone ki-left fs-1 pe-5">
          </i>
          <span>Detalle de ruta</span>
        </a>
        <!--end::Title-->

      </div>
      <!--end::Page title-->

    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <form class="form w-100" novalidate="novalidate" id="kt_detalleruta_in_form" data-kt-redirect-url="/" asp-controller="Corridas" asp-action="DetalleRuta" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="All" class="text-danger"></div>
      <input asp-for="CorridaId" type="hidden" />
      <input asp-for="CantidadEstaciones" type="hidden" />

      <div class="table-responsive">
        <table class="table">
          <thead>

            <tr class="fw-bold fs-5 text-gray-800">
              <th>Estaciones</th>
              <th>Hora llegada estimada</th>
              <th>Horarios</th>
            </tr>
          </thead>
          <tbody>
            @{
              TimeOnly horaInicio = new TimeOnly(0, 0);
            }
            @for (var i = 0; i < Model.Estaciones.Count; i++)
            {
              <tr>
                <td>
                  <span class="fw-bold fs-6 text-gray-600">
                    @Model.Estaciones[i].NombreEstacion
                  </span>
                </td>
                <td>
                  @if (i > 0)
                  {
                    var time = horaInicio.AddMinutes(Model.Estaciones[i - 1].Tiempo);
                    <span class="fw-bold fs-6 text-gray-600">
                      @time
                    </span>
                    horaInicio = time;
                  }
                  else
                  {
                    horaInicio = Model.Estaciones[i].Horario;
                  }
                </td>
                <td>
                  <div class="fv-row">
                    <input type="hidden" asp-for="Estaciones[i].NombreEstacion" />
                    <input type="hidden" asp-for="Estaciones[i].ParadaId" />
                    <div class="col-sm-6">
                      @{
                        var disabled = i == 0 || i == Model.Estaciones.Count - 1;
                      }
                      @* disabled="@disabled" *@
                      <input asp-for="Estaciones[i].Horario" type="time" class="form-control bg-transparent" readonly="@disabled" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Estaciones[i].Horario"></span>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>


      <div class="mb-10 text-end">

        <button type="submit" id="kt_detalleruta_in_submit" class="btn btn-primary">
          <!--begin::Indicator label-->
          <span class="indicator-label">Guardar</span>
          <!--end::Indicator label-->
          <!--begin::Indicator progress-->
          <span class="indicator-progress">
            Por favor espere...
            <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
          </span>
          <!--end::Indicator progress-->
        </button>
      </div>
    </form>
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/corridas/detalleruta.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}