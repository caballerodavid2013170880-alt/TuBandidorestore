@using SUVAN.BackOffice.Models.AppSettingsModels
@using SUVAN.BackOffice.Models.ViewModel.Configuracion;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@inject Microsoft.Extensions.Options.IOptions<GoogleSettingsOptions> GoogleSettingsOptions

@{
  ViewData["Title"] = "Estación";
}

@model AgregarEstacionViewModel
@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.estaciones);
  if (permisosPagina == null)
  {
    return;
  }
  var isAgaregarText = Model.EstacionId == 0 ? "Agregar" : "Editar";
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <a href="~/estaciones" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
          <i class="ki-duotone ki-left fs-1 pe-5">
          </i>
          <span>@isAgaregarText Estación</span>
        </a>
        <!--end::Title-->
      </div>
      <!--end::Page title-->
    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card">
      <!--begin::Card body-->
      <div class="card-body py-4">
        <div class="row">
          <div class="col-xl-6">
            <form class="form w-100" novalidate="novalidate" id="kt_estacion_in_form" data-kt-redirect-url="/" asp-controller="Estaciones" asp-action="AgregarEstacion" method="post">
              @Html.AntiForgeryToken()
              <input asp-for="EstacionId" type="hidden" />
              <div class="fv-row mb-8">
                <div class="col-md-12">
                  <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <div asp-validation-summary="All"></div>
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="col-md-12">
                  <div class="fv-row mb-8">
                    <label asp-for="NombreEstacion" class="col-md-12 col-form-label text-gray-600 required">Nombre de la estación</label>
                    <div class="col-md-12">
                      <input asp-for="NombreEstacion" class="form-control bg-transparent" placeholder="Nombre de la estación" maxlength="250" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="NombreEstacion"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="Latitud" class="col-md-12 col-form-label text-gray-600 required">Latitud</label>
                    <div class="col-md-12">
                      <input asp-for="Latitud" class="form-control bg-transparent" placeholder="Latitud" value="@Model.Latitud.ToString("F8")" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Latitud"></span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="Longitud" class="col-md-12 col-form-label text-gray-600 required">Longitud</label>
                    <div class="col-md-12">
                      <input asp-for="Longitud" class="form-control bg-transparent" placeholder="Longitud" value="@Model.Longitud.ToString("F8")" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Longitud"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="col-md-12">
                  <div class="fv-row mb-8">
                    <label asp-for="Calle" class="col-md-12 col-form-label text-gray-600 required">Nombre de la calle</label>
                    <div class="col-md-12">
                      <input asp-for="Calle" class="form-control bg-transparent" placeholder="Nombre de la calle" maxlength="250" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Calle"></span>
                      </div>

                    </div>
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="Numero" class="col-md-12 col-form-label text-gray-600 required">Número</label>
                    <div class="col-md-12">
                      <input asp-for="Numero" class="form-control bg-transparent" placeholder="Número" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Numero"></span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="Colonia" class="col-md-12 col-form-label text-gray-600 required">Colonia</label>
                    <div class="col-md-12">
                      <input asp-for="Colonia" class="form-control bg-transparent" placeholder="Colonia" maxlength="250" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Colonia"></span>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
              <div class="row">
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="Municipio" class="col-md-12 col-form-label text-gray-600 required">Alcaldía/Municipio</label>
                    <div class="col-md-12">
                      <input asp-for="Municipio" class="form-control bg-transparent" placeholder="Alcaldía/Municipio" maxlength="250" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Municipio"></span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="Ciudad" class="col-md-12 col-form-label text-gray-600 required">Ciudad</label>
                    <div class="col-md-12">
                      <input asp-for="Ciudad" class="form-control bg-transparent" placeholder="Ciudad" maxlength="250" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="Ciudad"></span>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
              <div class="row">
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <label asp-for="CodigoPostal" class="col-md-12 col-form-label text-gray-600 required">Código Postal</label>
                    <div class="col-md-12">
                      <input asp-for="CodigoPostal" class="form-control bg-transparent" placeholder="Código Postal" maxlength="10" />
                      <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                        <span asp-validation-for="CodigoPostal"></span>
                      </div>

                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="fv-row mb-8">
                    <div class="col-md-4">
                      <div class="form-check">
                        <label asp-for="Activo" class="form-check-label"></label>
                        <input asp-for="Activo" class="form-check-input" />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mb-10 text-end">
                <button type="submit" id="kt_estacion_in_submit" class="btn btn-primary">
                  <!--begin::Indicator label-->
                  <span class="indicator-label">Guardar</span>
                  <!--end::Indicator label-->
                  <!--begin::Indicator progress-->
                  <span class="indicator-progress">
                    Por favor espere...
                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                  </span>
                  <!--end::Indicator progress-->
                </button>
              </div>
            </form>
          </div>
          <div class="col-xl-6">
            <div class="row">
              <div class="col-md-12">
                <!--begin::Search-->
                <div class="d-flex align-items-center position-relative my-2">
                  <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                  <input type="text" id="search-place" class="form-control form-control-solid ps-13" placeholder="Buscar ubicación" />
                </div>
                <!--end::Search-->
              </div>
            </div>
            <div class="row">
              <div class="col-md-12">
                <div id="map" style="height: 550px; width: 100%;"></div>
              </div>
            </div>

          </div>
        </div>


      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/estaciones/add.js" asp-append-version="true"></script>
  <script src="https://maps.googleapis.com/maps/api/js?key=@GoogleSettingsOptions.Value.GoogleMapsApiKey&libraries=places&callback=KTEstacion.initMap" async defer></script>

  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>

}