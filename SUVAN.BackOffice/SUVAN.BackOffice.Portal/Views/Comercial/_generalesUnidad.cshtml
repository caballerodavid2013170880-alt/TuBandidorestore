@using SUVAN.BackOffice.Models.ViewModel.Comercial;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "DetalleUnidad";
}
@model List<ObtenerGeneralesUnidadesViewModel>

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.gestionDeUnidades);
    if (permisosPagina == null)
    {
        return;
    }
}


<table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_generales_unidad">
    <thead>
        <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
            <th class="min-w-125px">Tipo de unidad</th>
            <th class="min-w-125px">Placas</th>
            <th class="min-w-125px">Marca</th>
            <th class="min-w-125px">Modelo</th>
            <th class="min-w-125px">Número económico</th>
            <th class="min-w-125px">Número motor</th>
            <th class="min-w-125px">VIN</th>
        </tr>
    </thead>
    <tbody class="text-gray-600 fw-semibold">
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.TipoUnidad
                </td>
                <td>
                    @item.PlacasUnidad
                </td>
                <td>
                    @item.Marca
                </td>
                <td>
                    @item.Modelo
                </td>
                <td>
                    @item.NumeroEcoUnidad
                </td>
                <td>
                    @item.NumeroMotor
                </td>
                <td>
                    @item.VIN
                </td>
            </tr>

        }
    </tbody>
</table>