@using SUVAN.BackOffice.Models.ViewModel;
@using SUVAN.BackOffice.Models.ViewModel.Comercial;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Generar promoción";
}
<style type="text/css">
    .tipoPromocion {
        display:none;
    }
</style>
@model GeneraPromocionViewModel
@{
    string horarios = string.Empty;
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.codigosDePromocion);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.Promocion.PromocionId == 0 ? "Agregar" : "Editar";
    if (Model.Promocion.PromocionId != 0)
    {
        horarios = @Json.Serialize(@Model.Promocion.Horarios).ToString();
    }
}
<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <a href="~/Comercial/CodigosPromocion" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText Promoción</span>
                </a>
            </div>
        </div>
    </div>
</div>
<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">
        <div class="card">

            <form class="form w-100" novalidate="novalidate" id="kt_promocion_in_form" data-kt-redirect-url="/" asp-controller="Comercial" asp-action="GeneraPromocion" method="post" autocomplete="off">
                <div class="card-body py-4">
                    @Html.AntiForgeryToken()
                    <input asp-for="Promocion.PromocionId" class="form-control bg-transparent" type="hidden" />
                    <input id="hdHorarios" class="form-control bg-transparent" type="hidden" value="@horarios" />
                    <input asp-for="Promocion.FechaInicio" class="form-control bg-transparent" type="hidden" value="@Model.Promocion.FechaInicio?.ToString("dd/MM/yyyy")" />
                    <input asp-for="Promocion.FechaFin" class="form-control bg-transparent" type="hidden" value="@Model.Promocion.FechaFin?.ToString("dd/MM/yyyy")" />
                    <input asp-for="Promocion.EmpresaId" class="form-control bg-transparent" type="hidden" />
                    <div class="fv-row">
                        <div class="row">
                            <div class="col-sm-6">
                                <label asp-for="Promocion.Nombre" class="col-form-label text-gray-600 required">Nombre</label>
                                <input asp-for="Promocion.Nombre" class="form-control bg-transparent" placeholder="Nombre" maxlength="250" />
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="Promocion.Nombre"></span>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <label for="txtVigencia" class="col-form-label text-gray-600 required">Vigencia</label>
                                <input class="form-control bg-transparent" type="text" id="txtVigencia" name="txtVigencia" />
                            </div>
                            <div class="col-sm-3">
                                <label asp-for="Promocion.TipoPromocionId" class="col-form-label text-gray-600 required">Aplica a</label>
                                <select asp-for="Promocion.TipoPromocionId" asp-items="new SelectList(Model.TipoPromocion.Where(x=>x.TipoPromocionId!=1), nameof(TipoPromocionViewModel.TipoPromocionId), nameof(TipoPromocionViewModel.NombrePromocion), Model.Promocion.TipoPromocionId)" class="form-control">
                                    <option value="1">Empresa</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="Promocion.TipoPromocionId"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="fv-row">
                        <div class="row">
                            <div class="col-sm-3">
                                <label asp-for="Promocion.TipoDescuentoId" class="col-form-label text-gray-600 required">Tipo descuento</label>
                                <select asp-for="Promocion.TipoDescuentoId" asp-items="new SelectList(Model.TipoDescuento, nameof(TipoDescuentoViewModel.TipoDescuendoId), nameof(TipoDescuentoViewModel.NombreDescuento), Model.Promocion.TipoDescuentoId)" class="form-control">
                                    <option value="">Seleccione..</option>
                                </select>
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="Promocion.TipoDescuentoId"></span>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <label asp-for="Promocion.MontoDescuento" class="col-form-label text-gray-600 required">Descuento</label>
                                <input asp-for="Promocion.MontoDescuento" class="form-control bg-transparent" required />
                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                                    <span asp-validation-for="Promocion.MontoDescuento"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Promocion.NombreEmpresa" class="col-form-label text-gray-600 ">Empresa</label>
                                <input asp-for="Promocion.NombreEmpresa" class="form-control bg-transparent" disabled />
                            </div>

                        </div>
                    </div>
                    <div class="tipoPromocion tipoPromocion_ruta tipoPromocion_corrida tipoPromocion_horario">
                        <div class="separator separator-content border-dark my-15" id="divSeparator"><span class="w-250px fw-bold">Aplica a  Horario</span></div>
                        <div class="fv-row">
                            <div class="row">
                                <div class="col-sm-6 tipoPromocion tipoPromocion_ruta tipoPromocion_corrida">
                                    <label asp-for="Promocion.RutasEmpresa" class="col-form-label text-gray-600 ">Ruta</label>
                                    <select asp-for="Promocion.RutasEmpresa" asp-items="new SelectList(Model.RutaCorridas, nameof(RutaEmpresaViewModel.RutaId), nameof(RutaEmpresaViewModel.NombreRuta), Model.Promocion.RutasEmpresa.Select(x=>x.ToString()).ToArray())" class="form-select form-select-sm" data-control="select2" data-close-on-select="false" data-placeholder="Selecccione las rutas" data-allow-clear="true" multiple="multiple">
                                    </select>
                                </div>
                                <div class="col-sm-6 tipoPromocion tipoPromocion_corrida">
                                     @foreach (var grupo in Model.RutaCorridas.Where(x=>x.Corridas.Any()))
                                    {
                                        <div class="row divGroupRuta" style="display:none" id="divGroupRuta_@grupo.RutaId">
                                            <label class="col-form-label text-gray-600 ">@grupo.NombreRuta</label>
                                            @foreach (var corrida in grupo.Corridas)
                                            {
                                                <div class="form-check mb-5">
                                                    <input class="form-check-input" type="checkbox" value="@corrida.CorridaId" checked="@Model.Promocion.CorridasRutas.Contains(@corrida.CorridaId)" name="checboxCorridas" id="@string.Format("{0}_{1}_{2}","checkbox",@grupo.RutaId,@corrida.CorridaId)" />
                                                    <label class="form-check-label" for="flexCheckDefault">
                                                        @corrida.HoraInicio
                                                    </label>
                                                </div>
                                            }

                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="fv-row tipoPromocion tipoPromocion_horario">
                            <div class="row">
                                @if (@Model.Promocion.PromocionId == 0)
                                {
                                    <div class="col-sm-2 ">
                                        <label class="col-form-label text-gray-600 ">Inicia a</label>
                                        <input id="txtHoraInicio" class="form-control bg-transparent" name="txtHoraInicio" />
                                    </div>
                                    <div class="col-sm-2 ">
                                        <label class="col-form-label text-gray-600 ">Termina a</label>
                                        <input id="txtHoraFin" class="form-control bg-transparent" name="txtHoraFin" type="time" />
                                    </div>
                                    <div class="col-sm-2 text-start">
                                        <a href="javaScript:void(0)" id="btnAgregarHorario" class="btn btn-outline btn-outline-dashed btn-outline-primary btn-active-light-primary mt-10"><i class="bi bi-calendar-plus"></i>Agregar</a>
                                    </div>
                                    
                                }

                                <div class="col-sm-6">
                                    <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_horarios">
                                        <thead>
                                            <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">

                                                <th class="min-w-125px">No</th>
                                                <th class="min-w-125px">Horario</th>
                                                <th class="text-end min-w-100px">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody class="text-gray-600 fw-semibold">

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                @if (@Model.Promocion.PromocionId == 0)
                {
                    <div class="card-footer text-end">
                        <button type="submit" id="kt_add_promocion_in_submit" class="btn btn-primary">
                            <span class="indicator-label">Guardar</span>
                            <span class="indicator-progress">
                                Por favor espere...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                }

            </form>

        </div>
    </div>
</div>
@section scripts {

    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
    <script src="~/js/comercial/jsgenerapromocion.js"></script>
}
