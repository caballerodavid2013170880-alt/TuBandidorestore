@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper

@{
  ViewData["Title"] = "Descuentos";
}
@model List<SUVAN.BackOffice.Database.Entities.Codigodescuento>

@{
  var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.descuentos);
  if (permisosPagina == null)
  {
    return;
  }
}

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar ">
  <!--begin::Toolbar container-->
  <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
    <!--begin::Toolbar wrapper-->
    <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
      <!--begin::Page title-->
      <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
        <!--begin::Title-->
        <h1 class="page-heading d-flex flex-column justify-content-center text-dark fw-bold fs-3 m-0">Códigos de descuento</h1>
        <!--end::Title-->

      </div>
      <!--end::Page title-->
      <!--begin::Actions-->
      <div class="d-flex align-items-center gap-2 gap-lg-3">
        @if (permisosPagina!.Agregar)
        {
          <a href="~/descuentos/agregar" class="btn btn-flex btn-outline btn-color-gray-700 btn-active-color-primary bg-body h-40px fs-7 fw-bold">Agregar código</a>
        }

      </div>
      <!--end::Actions-->
    </div>
    <!--end::Toolbar wrapper-->
  </div>
  <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
  <!--begin::Content container-->
  <div id="kt_app_content_container" class="app-container container-fluid">
    <!--begin::Card-->
    <div class="card">
      <!--begin::Card header-->
      <div class="card-header border-0 pt-6">
        <!--begin::Card title-->
        <div class="card-title">
          <!--begin::Search-->
          <div class="d-flex align-items-center position-relative my-1">
            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
            <input type="text" data-kt-descuentos-table-filter="search" class="form-control form-control-solid w-450px ps-13" placeholder="Buscar" />
          </div>
          <!--end::Search-->
        </div>
        <!--begin::Card title-->

      </div>
      <!--end::Card header-->
      <!--begin::Card body-->
      <div class="card-body py-4">
        <!--begin::Table-->
        <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_descuentos">
          <thead>
            <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">

              <th class="min-w-125px">Código</th>
              <th class="min-w-125px">Aplica a</th>
              <th class="min-w-125px">Vigencia</th>
              <th class="text-end min-w-100px">Acciones</th>
            </tr>
          </thead>
          <tbody class="text-gray-600 fw-semibold">

            @foreach (var descuento in Model)
            {
              <tr>
                <td>
                  <input type="hidden" data-kt-descuentos-table-filter="row_id" value="@descuento.Idcodigodescuento" />
                  @descuento.Codigo
                </td>
                <td>
                  @{
                    var aplicaA = descuento.TipocodigodescuentoIdtipocodigodescuento == (int)EnumTipoCodigo.General ? "General" : "Exclusivo";
                  }
                  @aplicaA

                </td>
                <td>
                  @{
                    var vigencia = Convert.ToDateTime(descuento.Vigenciadesde).ToString("dd/MM/yyyy") + " - " + Convert.ToDateTime(descuento.Vigenciahasta).ToString("dd/MM/yyyy");
                  }
                  @vigencia
                </td>


                <td class="text-end">

                  @if (permisosPagina!.Editar)
                  {
                    <a href="~/descuentos/agregar/@descuento.Idcodigodescuento" class="btn btn-icon btn-active-light-primary w-30px h-30px">
                      <i class="ki-outline ki-pencil fs-3"></i>
                    </a>
                  }

                </td>
              </tr>

            }



          </tbody>
        </table>
        <!--end::Table-->
      </div>
      <!--end::Card body-->
    </div>
    <!--end::Card-->
  </div>
  <!--end::Content container-->
</div>
<!--end::Content-->
@section scripts {
  <script src="~/js/configuracion/descuentos/table.js" asp-append-version="true"></script>
  <script src="~/assets/js/widgets.bundle.js"></script>
  <script src="~/assets/js/custom/widgets.js"></script>
  <script src="~/assets/js/custom/utilities/modals/users-search.js" asp-append-version="true"></script>

}