@using SUVAN.BackOffice.Models.ViewModel.Logistica;
@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Vehiculo Detalles";
}

@model VehiculoEspecificacionesViewModel
@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoEspecificaciones);
    if (permisosPagina == null)
    {
        return;
    }
    var isAgaregarText = Model.IdEspecificaciones == 0 ? "Agregar" : "Editar";
}

<div id="kt_app_toolbar" class="app-toolbar ">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex align-items-stretch">
        <div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
            <div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
                <a href="~/VehiculoEspecificaciones/Index" class="page-heading d-flex justify-content-center align-center text-dark fw-bold fs-3 m-0 ">
                    <i class="ki-duotone ki-left fs-1 pe-5">
                    </i>
                    <span>@isAgaregarText Especificaciones</span>
                </a>
            </div>
        </div>
    </div>
</div>
<div class="container mt-5">
    <div class="mx-auto d-flex flex-column align-items-center">
        <ul class="nav nav-pills d-flex justify-content-center mb-2" id="listaHorizontalFila1">
            <li class="nav-item">
                <a class="nav-link active" id="dimensioncapacidad-tab" data-bs-toggle="tab" href="#dimensioncapacidad">Dimensión y Capacidad</a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" id="motordesempeno-tab" data-bs-toggle="tab" href="#motordesempeno">Motor y Desempeño</a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" id="transmisiontraccion-tab" data-bs-toggle="tab" href="#transmisiontraccion">Transmisión y Tracción</a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" id="datosadicionales-tab" data-bs-toggle="tab" href="#datosadicionales">Datos Adicionales</a>
            </li>
        </ul>
    </div>

    <form class="form w-100" id="kt_especificaciones_in_form" data-kt-redirect-url="/" asp-controller="VehiculoEspecificaciones" asp-action="NavegacionVehiculoEspecificaciones" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="IdEspecificaciones" type="hidden" />
        <input asp-for="IdMarca" type="hidden" />
        <input asp-for="IdModelo" type="hidden" />
        <div class="fv-row mb-8">
            <div class="col-sm-12">
                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback">
                    <div asp-validation-summary="All"></div>
                </div>
            </div>
        </div>
        <div class="tab-content" id="contenidoPestanas">
            <div class="tab-pane fade show active" id="dimensioncapacidad">
                @await Html.PartialAsync("_dimensionCapacidad", Model)
            </div>

            <div class="tab-pane fade" id="motordesempeno">
                @await Html.PartialAsync("_motorDesempeno", Model)
            </div>

            <div class="tab-pane fade" id="transmisiontraccion">
                @await Html.PartialAsync("_transmisionTraccion", Model)
            </div>
            
            <div class="tab-pane fade" id="datosadicionales">
                @await Html.PartialAsync("_datosAdicionales", Model)
            </div>
        </div>
    </form>
</div>

<div class="modal modal-lg fade" tabindex="-1" id="kt_modal_detalle" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitulo">Título</h5>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body" id="modal-body">
                <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_tabla_detalle">
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
<!--end::Toolbar-->
<!--begin::Content-->
<!--end::Content-->
@section scripts {
    <script src="~/js/logistica/vehiculoespecifi/validaciones.js"></script>
    <script src="~/js/logistica/vehiculoespecifi/navvehiculoespecifi.js"></script>
    <script src="~/assets/js/widgets.bundle.js"></script>
    <script src="~/assets/js/custom/widgets.js"></script>
}