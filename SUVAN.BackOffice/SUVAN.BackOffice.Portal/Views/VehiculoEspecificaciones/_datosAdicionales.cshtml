@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Logistica
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Datos Adicionales";
}
@model VehiculoEspecificacionesViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoEspecificaciones);
    if (permisosPagina == null)
    {
        return;
    }
}
<div class="card card-bordered mb-5">
    <div class="card-header">
        <h3 class="card-title">Datos Adicionales</h3>
    </div>
    <div class="card-body py-2">
        <div class="row">
            <div class="col-sm-2 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="Origen" class="col-form-label text-gray-600 required">Origen</label>
                    <input asp-for="Origen" class="form-control form-control-sm bg-transparent" placeholder="Origen" />
                    <span asp-validation-for="Origen" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="Observaciones" class="col-form-label text-gray-600">Observaciones</label>
                    <input asp-for="Observaciones" class="form-control form-control-sm bg-transparent" placeholder="Observaciones" />
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-primary btn-sm" onclick="irATabAnterior()">Anterior</button>
            <button type="submit" id="kt_especificaciones_in_submit" class="btn btn-primary btn-sm">
                <span class="indicator-label">Guardar</span>
                <span class="indicator-progress">
                    Por favor espere...
                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                </span>
            </button>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/logistica/vehiculoespecifi/validaciones.js"></script>
    <script src="~/js/logistica/vehiculoespecifi/add.js"></script>
    <script src="~/js/logistica/vehiculoespecifi/navvehiculoespecifi.js"></script>
}