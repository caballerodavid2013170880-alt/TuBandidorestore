@using SUVAN.BackOffice.Models.ViewModel.Enums;
@using SUVAN.BackOffice.Models.ViewModel.Logistica
@using SUVAN.BackOffice.Portal.Helper;
@inject IUsuarioHelper UsuarioHelper
@{
    ViewData["Title"] = "Motor y Desempeño";
}
@model VehiculoEspecificacionesViewModel

@{
    var permisosPagina = await UsuarioHelper.GetPermisosPagina(User, EnumOpcionMenu.VehiculoEspecificaciones);
    if (permisosPagina == null)
    {
        return;
    }
}
<div class="card card-bordered mb-5">
    <div class="card-header">
        <h3 class="card-title">Motor y Desempeño</h3>
    </div>
    <div class="card-body py-2">
        <div class="row">
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="TipoMotor" class="col-form-label text-gray-600 required">Tipo de Motor</label>
                    <input asp-for="TipoMotor" type="text" class="form-control form-control-sm bg-transparent" placeholder="Tipo de Motor" />
                    <span asp-validation-for="TipoMotor" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="PotenciaMotor" class="col-form-label text-gray-600 required">Potencia del Motor</label>
                    <input asp-for="PotenciaMotor" type="text" class="form-control form-control-sm bg-transparent" placeholder="Potencia del Motor" />
                    <span asp-validation-for="PotenciaMotor" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="NoCilindros" class="col-form-label text-gray-600 required">No. de Cilindros</label>
                    <input asp-for="NoCilindros" type="text" class="form-control form-control-sm bg-transparent" placeholder="No. de Cilindros" />
                    <span asp-validation-for="NoCilindros" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-3 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="CapacidadAceite" class="col-form-label text-gray-600 required">Capacidad de Aceite</label>
                    <input asp-for="CapacidadAceite" type="text" class="form-control form-control-sm bg-transparent" placeholder="Capacidad de Aceite" />
                    <span asp-validation-for="CapacidadAceite" class="invalid-feedback"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="CapacidadCombu" class="col-form-label text-gray-600 required">Capacidad de Combustible</label>
                    <input asp-for="CapacidadCombu" type="text" class="form-control form-control-sm bg-transparent" placeholder="Capacidad de Combustible" />
                    <span asp-validation-for="CapacidadCombu" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="RenEsp" class="col-form-label text-gray-600 required">Rendimiento Especial</label>
                    <input asp-for="RenEsp" type="text" class="form-control form-control-sm bg-transparent" placeholder="Rendimiento Especial" />
                    <span asp-validation-for="RenEsp" class="invalid-feedback"></span>
                </div>
            </div>
            <div class="col-sm-4 mb-2">
                <div class="fv-row mb-2">
                    <label asp-for="TipoCombustible" class="col-form-label text-gray-600 required">Tipo de Combustible</label>
                    <input asp-for="TipoCombustible" type="text" class="form-control form-control-sm bg-transparent" placeholder="Tipo de Combustible" />
                    <span asp-validation-for="TipoCombustible" class="invalid-feedback"></span>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-primary btn-sm" onclick="irATabAnterior()">Anterior</button>
            <button type="button" class="btn btn-primary btn-sm btn-next-tab" data-current="motordesempeno" data-next="transmisiontraccion">Siguiente </button>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/logistica/vehiculoespecifi/validaciones.js"></script>
    <script src="~/js/logistica/vehiculoespecifi/add.js"></script>
    <script src="~/js/logistica/vehiculoespecifi/navvehiculoespecifi.js"></script>
}